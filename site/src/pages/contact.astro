---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
import { absoluteUrl, breadcrumbJsonLd, personJsonLd, buildPageTitle } from "../lib/seo";

const contactJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: `Contact ${profile.name}`,
    url: absoluteUrl("/contact"),
    description: `Contact ${profile.name} for digital marketing, SEO, and web systems work in Dubai and the UAE.`,
    mainEntity: {
      "@type": "Person",
      name: profile.name,
      url: profile.siteUrl,
    },
  },
  personJsonLd(),
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "Contact", path: "/contact" },
  ]),
];
---

<BaseLayout
  title={buildPageTitle("Contact for Dubai SEO, Growth & Web Systems")}
  description={`Start a project with ${profile.name} for digital marketing, technical SEO, lead generation, and web systems in Dubai.`}
  path="/contact"
  jsonLd={contactJsonLd}
>

<section class="py-20 px-4">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-3" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-[0.3em] text-accent-soft/70">Contact</p>
    </div>
    <div class="reveal mb-3" data-delay="0.10">
      <h1 class="font-display font-bold text-white text-balance"
        style="font-size: clamp(2rem, 4.5vw, 3.5rem); letter-spacing: -0.035em;">
        Start with a focused brief
      </h1>
    </div>
    <div class="reveal mb-10" data-delay="0.15">
      <p class="text-base text-slate-400 max-w-xl leading-relaxed">
        Share your goals, timeline, and current blockers. WhatsApp is fastest — I respond within hours.
      </p>
    </div>
    <div class="reveal flex flex-wrap gap-3 mb-16" data-delay="0.20">
      <a href={profile.links.whatsapp} target="_blank" rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-white"
        style="background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 4px 24px rgba(37,99,235,0.4);">
        ↗ Message on WhatsApp
      </a>
      <a href={profile.links.email}
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors">
        Send Email
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-[1.3fr,0.7fr] items-start">

      <!-- Form -->
      <div class="reveal glass-panel rounded-2xl p-8" data-delay="0.10">
        <h2 class="font-display font-semibold text-white text-lg mb-7">Send project details</h2>
        <form
          name="contact"
          method="POST"
          action="/contact/?success=true#thanks"
          class="space-y-5"
        >

          {[
            { id: "name", label: "Name", type: "text", placeholder: "Your name" },
            { id: "email", label: "Email", type: "email", placeholder: "you@company.com" },
          ].map(({ id, label, type, placeholder }) => (
            <div>
              <label for={id} class="block text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">{label}</label>
              <input
                id={id} name={id} type={type} required
                placeholder={placeholder}
                class="w-full rounded-xl px-4 py-3 text-sm text-white placeholder:text-slate-700 outline-none transition-all focus:border-accent-soft/40"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);"
                onfocus="this.style.borderColor='rgba(147,197,253,0.35)'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.12)'"
                onblur="this.style.borderColor='rgba(255,255,255,0.10)'; this.style.boxShadow='none'"
              />
            </div>
          ))}

          <div>
            <label for="message" class="block text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Message</label>
            <textarea
              id="message" name="message" rows="5" required
              placeholder="Project goals, timeline, and current blockers"
              class="w-full rounded-xl px-4 py-3 text-sm text-white placeholder:text-slate-700 outline-none resize-none transition-all"
              style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);"
              onfocus="this.style.borderColor='rgba(147,197,253,0.35)'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.12)'"
              onblur="this.style.borderColor='rgba(255,255,255,0.10)'; this.style.boxShadow='none'"
            ></textarea>
          </div>

          <button type="submit"
            class="w-full rounded-full py-3.5 text-sm font-semibold text-white transition-all duration-300 hover:scale-[1.01]"
            style="background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 4px 24px rgba(37,99,235,0.4), inset 0 1px 0 rgba(255,255,255,0.15);">
            Submit Request →
          </button>
        </form>
      </div>

      <!-- Direct Channels -->
      <div class="space-y-5">
        <div class="reveal glass-panel rounded-2xl p-7" data-delay="0.14">
          <h2 class="font-display font-semibold text-white text-base mb-6">Direct channels</h2>
          <div class="space-y-5">
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-slate-600 mb-1">WhatsApp</p>
              <a href={profile.links.whatsapp} target="_blank" rel="noreferrer"
                class="text-sm text-slate-300 hover:text-accent-soft transition-colors">
                {profile.whatsappDisplay}
              </a>
            </div>
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-slate-600 mb-1">Email</p>
              <a href={profile.links.email} class="text-sm text-slate-300 hover:text-accent-soft transition-colors">
                {profile.email}
              </a>
            </div>
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-slate-600 mb-1">Website</p>
              <a href={profile.siteUrl} class="text-sm text-slate-300 hover:text-accent-soft transition-colors">
                {profile.siteUrl}
              </a>
            </div>
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-slate-600 mb-1">Instagram</p>
              <a href={profile.links.instagram} target="_blank" rel="noreferrer me"
                class="text-sm text-slate-300 hover:text-accent-soft transition-colors">
                {profile.links.instagramHandle}
              </a>
            </div>
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-slate-600 mb-1">Location</p>
              <p class="text-sm text-slate-400">{profile.location}</p>
            </div>
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-slate-600 mb-1">Press kit</p>
              <a href="/press-kit" class="text-sm text-slate-300 hover:text-accent-soft transition-colors">
                Official bio and brand links
              </a>
            </div>
          </div>
        </div>

        <div class="reveal glass-panel rounded-2xl p-7" data-delay="0.19">
          <p class="text-xs font-mono uppercase tracking-widest text-slate-600 mb-3">Response time</p>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
            <p class="text-sm text-slate-300">Usually within a few hours on WhatsApp</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="pb-20 px-4 section-border">
  <div class="mx-auto max-w-6xl pt-14">
    <div class="reveal mb-8" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-[0.3em] text-accent-soft/70 mb-3">Helpful Paths</p>
      <h2 class="font-display font-semibold text-white text-2xl">Start from the page that matches the problem</h2>
      <p class="mt-4 max-w-3xl text-sm text-slate-400 leading-loose">
        If you are still scoping the project, these pages give the clearest context:
        <a href="/services/dubai-technical-seo" class="text-accent-soft hover:text-white transition-colors"> technical SEO</a>,
        <a href="/services/dubai-digital-marketing" class="text-accent-soft hover:text-white transition-colors"> digital marketing</a>,
        <a href="/services/dubai-web-development-web-apps" class="text-accent-soft hover:text-white transition-colors"> web development</a>,
        <a href="/services/dubai-ai-systems-automation-geo" class="text-accent-soft hover:text-white transition-colors"> AI systems and GEO</a>,
        <a href="/services/dubai-lead-generation-web-systems" class="text-accent-soft hover:text-white transition-colors"> lead-generation web systems</a>,
        the <a href="/work" class="text-accent-soft hover:text-white transition-colors">case studies</a>,
        and the role-fit pages for <a href="/dubai-digital-marketer" class="text-accent-soft hover:text-white transition-colors">digital marketing</a>,
        <a href="/dubai-web-developer" class="text-accent-soft hover:text-white transition-colors"> web development</a>, and
        <a href="/dubai-ai-engineer" class="text-accent-soft hover:text-white transition-colors"> AI and GEO</a>, plus the
        <a href="/generative-engine-optimization-specialist-dubai" class="text-accent-soft hover:text-white transition-colors"> generative engine optimization specialist page</a>.
      </p>
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-6">
      <a href="/services/dubai-technical-seo" class="reveal glass-panel ring-hover rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1" data-delay="0.08">
        <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/70 mb-3">Dubai SEO</p>
        <p class="text-sm text-slate-400 leading-loose">Site architecture, crawlability, structured data, and internal linking.</p>
      </a>
      <a href="/services/dubai-digital-marketing" class="reveal glass-panel ring-hover rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1" data-delay="0.12">
        <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/70 mb-3">Campaigns</p>
        <p class="text-sm text-slate-400 leading-loose">Meta, Google, creative testing, landing flows, and reporting.</p>
      </a>
      <a href="/services/dubai-lead-generation-web-systems" class="reveal glass-panel ring-hover rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1" data-delay="0.16">
        <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/70 mb-3">Lead Systems</p>
        <p class="text-sm text-slate-400 leading-loose">Funnels, WhatsApp conversion logic, WordPress systems, and measurement.</p>
      </a>
      <a href="/work" class="reveal glass-panel ring-hover rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1" data-delay="0.20">
        <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/70 mb-3">Proof</p>
        <p class="text-sm text-slate-400 leading-loose">Case studies showing lead generation, growth ops, and operational delivery.</p>
      </a>
      <a href="/dubai-web-developer" class="reveal glass-panel ring-hover rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1" data-delay="0.24">
        <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/70 mb-3">Web Developer</p>
        <p class="text-sm text-slate-400 leading-loose">Developer, web-app, and programmer profile path for build-focused projects.</p>
      </a>
      <a href="/dubai-ai-engineer" class="reveal glass-panel ring-hover rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1" data-delay="0.28">
        <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/70 mb-3">AI and GEO</p>
        <p class="text-sm text-slate-400 leading-loose">AI systems, automation, SEO, GEO, and discovery-focused profile path.</p>
      </a>
    </div>
  </div>
</section>

<!-- Thanks -->
<div id="thanks-wrapper" class="hidden px-4 pb-16">
  <div class="mx-auto max-w-6xl">
    <div id="thanks" class="glass-panel-strong rounded-2xl p-10 text-center">
      <div class="text-3xl mb-4">✓</div>
      <h2 class="font-display font-semibold text-white text-xl mb-2">Message received.</h2>
      <p class="text-slate-400 mb-7">Continue on WhatsApp for faster follow-up and project scoping.</p>
      <a href={profile.links.whatsapp} target="_blank" rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-sm font-semibold text-white"
        style="background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 4px 24px rgba(37,99,235,0.4);">
        ↗ Open WhatsApp
      </a>
    </div>
  </div>
</div>

<script is:inline>
  const p = new URLSearchParams(window.location.search);
  if (p.get("success") === "true") {
    const w = document.getElementById("thanks-wrapper");
    const t = document.getElementById("thanks");
    if (w) w.classList.remove("hidden");
    if (t) t.scrollIntoView({ behavior: "smooth", block: "start" });
  }
</script>

</BaseLayout>
