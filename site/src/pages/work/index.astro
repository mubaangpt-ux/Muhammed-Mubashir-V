---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CreativeWorks from "../../components/CreativeWorks";
import WorkSequenceHero from "../../components/work/WorkSequenceHero";
import { profile } from "../../data/profile";
import { projects } from "../../data/projects";
import { absoluteUrl, breadcrumbJsonLd, workCollectionJsonLd, buildPageTitle } from "../../lib/seo";
import {
  WORK_HERO_IMAGE_ALT,
  WORK_HERO_IMAGE_CAPTION,
  WORK_HERO_IMAGE_HEIGHT,
  WORK_HERO_IMAGE_WIDTH,
  WORK_HERO_POSTER_SRC,
} from "../../lib/work-sequence";

const workSequenceImageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ImageObject",
  url: absoluteUrl(WORK_HERO_POSTER_SRC),
  contentUrl: absoluteUrl(WORK_HERO_POSTER_SRC),
  name: "Dubai skyline motherboard sequence poster",
  description: WORK_HERO_IMAGE_CAPTION,
  caption: WORK_HERO_IMAGE_CAPTION,
  width: WORK_HERO_IMAGE_WIDTH,
  height: WORK_HERO_IMAGE_HEIGHT,
  representativeOfPage: true,
  creator: {
    "@type": "Person",
    name: profile.name,
    url: profile.siteUrl,
  },
  keywords:
    "Dubai web development, digital marketing Dubai, technical SEO Dubai, GEO specialist Dubai, AI systems Dubai, cinematic Dubai skyline sequence",
};

const workJsonLd = [
  workCollectionJsonLd(),
  workSequenceImageJsonLd,
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "Work", path: "/work" },
  ]),
];

const featuredProjects = projects.filter((project) => project.featured);
const leadProject = featuredProjects[0];
const secondaryFeaturedProjects = featuredProjects.slice(1);
const sequenceCaseStudy = projects.find((project) => project.slug === "dubai-skyline-sequence-hero");
const supportingProjects = projects.filter(
  (project) => !project.featured && project.slug !== "dubai-skyline-sequence-hero",
);
---

<BaseLayout
  title={buildPageTitle("Case Studies & Creative Work")}
  description="Case studies in digital marketing, web development, technical SEO, GEO, AI systems, lead generation, and creative work for Dubai and UAE brands."
  path="/work"
  image={WORK_HERO_POSTER_SRC}
  ogTitle="Dubai web development, SEO, GEO, and digital marketing case studies | Muhammed Mubashir V"
  ogDescription={WORK_HERO_IMAGE_ALT}
  jsonLd={workJsonLd}
>

<WorkSequenceHero client:load />

<section id="work-cases" class="relative z-10 -mt-20 px-4 pt-28 pb-20">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-3" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-[0.3em] text-accent-soft/70">Work</p>
    </div>
    <div class="reveal mb-16" data-delay="0.10">
      <h2 class="font-display font-bold text-white" style="font-size: clamp(2.2rem, 5vw, 3.5rem); letter-spacing: -0.035em;">
        Projects & case studies
      </h2>
      <p class="text-base text-slate-400 mt-4 max-w-xl leading-relaxed">
        Selected work with measurable operational and growth outcomes across UAE markets.
      </p>
      <div class="mt-6">
        <a
          href="/services"
          class="inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-medium transition-all duration-300"
          style="border: 1px solid rgba(255,255,255,0.12); color: #93c5fd; background: rgba(37,99,235,0.08);"
        >
          Explore Dubai service pages →
        </a>
      </div>
    </div>

    {leadProject && (
      <div class="grid gap-5 lg:grid-cols-[minmax(0,1.25fr)_minmax(0,0.95fr)]">
        <a
          href={`/work/${leadProject.slug}`}
          class="reveal glass-panel ring-hover rounded-[1.75rem] p-8 group flex flex-col justify-between min-h-[26rem] hover:-translate-y-1 transition-all duration-300"
          data-delay="0.05"
        >
          <div>
            <div class="flex items-center justify-between gap-3 mb-6">
              <span class="text-xs font-mono uppercase tracking-[0.28em] text-accent-soft/70">{leadProject.category}</span>
              <span class="rounded-full px-3 py-1 text-[11px] font-mono"
                style="border: 1px solid rgba(37,99,235,0.30); background: rgba(37,99,235,0.10); color: #93c5fd;">
                Lead case study
              </span>
            </div>
            <h2 class="font-display font-semibold text-white text-2xl md:text-[2rem] leading-tight max-w-xl">
              {leadProject.title}
            </h2>
            <p class="mt-3 text-xs font-mono uppercase tracking-[0.24em] text-slate-600">
              {leadProject.client} · {leadProject.period}
            </p>
            <p class="mt-6 max-w-2xl text-base leading-relaxed text-slate-400">
              {leadProject.overview}
            </p>
          </div>

          <div class="mt-8 grid gap-5 md:grid-cols-[1.05fr_0.95fr]">
            <div class="rounded-2xl border border-white/6 bg-white/[0.025] p-5">
              <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-600 mb-4">Outcome Signals</p>
              <div class="space-y-3">
                {leadProject.results.slice(0, 3).map((result) => (
                  <p class="text-sm leading-relaxed text-slate-300">{result}</p>
                ))}
              </div>
            </div>
            <div class="rounded-2xl border border-white/6 bg-white/[0.025] p-5">
              <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-600 mb-4">Delivery Stack</p>
              <div class="flex flex-wrap gap-2">
                {leadProject.tools.slice(0, 5).map((tool) => (
                  <span class="text-xs px-2.5 py-1 rounded-full text-slate-500 font-mono"
                    style="border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03);">
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <div class="mt-7 flex items-center gap-1.5 text-xs text-accent-soft/60 group-hover:text-accent-soft transition-colors font-mono">
            View case study <span class="group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </a>

        <div class="grid gap-5">
          {secondaryFeaturedProjects.map((project, index) => (
            <a
              href={`/work/${project.slug}`}
              class="reveal glass-panel ring-hover rounded-[1.5rem] p-6 group flex flex-col justify-between min-h-[12.5rem] hover:-translate-y-1 transition-all duration-300"
              data-delay={String(0.10 + index * 0.06)}
            >
              <div>
                <div class="flex items-center justify-between gap-3 mb-4">
                  <span class="text-xs font-mono uppercase tracking-[0.24em] text-accent-soft/70">{project.category}</span>
                  <span class="text-xs font-mono text-slate-700">{String(index + 2).padStart(2, "0")}</span>
                </div>
                <h3 class="font-display font-semibold text-white text-xl leading-snug">{project.title}</h3>
                <p class="mt-3 text-xs font-mono uppercase tracking-[0.24em] text-slate-600">
                  {project.client} · {project.period}
                </p>
                <p class="mt-4 text-sm leading-relaxed text-slate-400">{project.overview}</p>
              </div>

              <div class="mt-5 flex items-center gap-1.5 text-xs text-accent-soft/50 group-hover:text-accent-soft transition-colors font-mono">
                View case study <span class="group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {supportingProjects.length > 0 && (
      <div class="mt-12">
        <div class="reveal mb-8" data-delay="0.18">
          <p class="text-xs font-mono uppercase tracking-[0.24em] text-slate-600 mb-3">More Work</p>
          <h2 class="font-display font-semibold text-white text-2xl">Supporting case studies</h2>
        </div>

        {sequenceCaseStudy && (
          <a
            href={`/work/${sequenceCaseStudy.slug}`}
            class="reveal glass-panel ring-hover mb-5 grid gap-5 rounded-[1.75rem] p-6 transition-all duration-300 hover:-translate-y-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(20rem,0.9fr)]"
            data-delay="0.20"
          >
            <div class="min-w-0">
              <div class="mb-4 flex items-center justify-between gap-3">
                <span class="text-xs font-mono uppercase tracking-[0.28em] text-accent-soft/70">{sequenceCaseStudy.category}</span>
                <span
                  class="rounded-full px-3 py-1 text-[11px] font-mono"
                  style="border: 1px solid rgba(37,99,235,0.30); background: rgba(37,99,235,0.10); color: #93c5fd;"
                >
                  Hero sequence
                </span>
              </div>
              <h3 class="font-display font-semibold text-white text-2xl leading-tight">
                {sequenceCaseStudy.title}
              </h3>
              <p class="mt-3 text-xs font-mono uppercase tracking-[0.24em] text-slate-600">
                {sequenceCaseStudy.client} · {sequenceCaseStudy.period}
              </p>
              <p class="mt-5 max-w-2xl text-sm leading-relaxed text-slate-400">{sequenceCaseStudy.overview}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {sequenceCaseStudy.tools.slice(0, 5).map((tool) => (
                  <span
                    class="text-xs px-2.5 py-1 rounded-full text-slate-500 font-mono"
                    style="border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03);"
                  >
                    {tool}
                  </span>
                ))}
              </div>
            </div>

            <div class="rounded-[1.5rem] border border-white/8 bg-white/[0.03] p-4">
              <img
                src={sequenceCaseStudy.image}
                alt="Dubai skyline sequence hero poster frame"
                class="w-full rounded-[1.15rem] border border-white/8 object-cover"
                loading="lazy"
              />
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {sequenceCaseStudy.techniques?.slice(0, 2).map((technique) => (
                  <div class="rounded-[1rem] border border-white/6 bg-black/10 p-3">
                    <p class="text-[10px] font-mono uppercase tracking-[0.24em] text-slate-500">Technique</p>
                    <p class="mt-2 text-sm leading-relaxed text-slate-300">{technique}</p>
                  </div>
                ))}
              </div>
              <div class="mt-4 text-xs font-mono text-accent-soft/60 transition-colors">
                View case study →
              </div>
            </div>
          </a>
        )}

        <div class="grid gap-5 md:grid-cols-2">
          {supportingProjects.map((project, index) => (
            <a
              href={`/work/${project.slug}`}
              class="reveal glass-panel ring-hover rounded-2xl p-6 group flex flex-col hover:-translate-y-1 transition-all duration-300"
              data-delay={String(0.22 + index * 0.06)}
            >
              <div class="flex items-center justify-between gap-3 mb-4">
                <span class="text-xs font-mono uppercase tracking-[0.24em] text-accent-soft/70">{project.category}</span>
                <span class="text-xs font-mono text-slate-700">{project.client}</span>
              </div>

              <h3 class="font-display font-semibold text-white text-lg leading-snug">{project.title}</h3>
              <p class="mt-2 text-xs font-mono uppercase tracking-[0.24em] text-slate-600">{project.period}</p>
              <p class="mt-4 text-sm text-slate-400 leading-relaxed flex-1">{project.overview}</p>

              <div class="mt-5 flex flex-wrap gap-2">
                {project.tools.slice(0, 3).map((tool) => (
                  <span class="text-xs px-2.5 py-1 rounded-full text-slate-600 font-mono"
                    style="border: 1px solid rgba(255,255,255,0.07); background: rgba(255,255,255,0.03);">
                    {tool}
                  </span>
                ))}
              </div>

              <div class="mt-5 flex items-center gap-1.5 text-xs text-accent-soft/50 group-hover:text-accent-soft transition-colors font-mono">
                View case study <span class="group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<CreativeWorks client:visible />

</BaseLayout>
