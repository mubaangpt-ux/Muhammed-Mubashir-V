---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
import { experience } from "../data/experience";
import { skillGroups } from "../data/skills";
import { education } from "../data/education";
import { breadcrumbJsonLd, personJsonLd, profilePageJsonLd, buildPageTitle } from "../lib/seo";

const resumeJsonLd = [
  profilePageJsonLd("/resume"),
  personJsonLd(),
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "Resume", path: "/resume" },
  ]),
];
---

<BaseLayout
  title={buildPageTitle("Resume & Experience")}
  description={`${profile.name} resume, experience, skills, and education in digital marketing, web development, technical SEO, GEO, AI systems, and web-app operations.`}
  path="/resume"
  jsonLd={resumeJsonLd}
>

<section class="py-20 px-4">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-3" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-[0.3em] text-accent-soft/70">Resume</p>
    </div>
    <div class="reveal mb-1" data-delay="0.10">
      <h1 class="font-display font-bold text-white" style="font-size: clamp(2.2rem, 5vw, 3.5rem); letter-spacing: -0.035em;">
        {profile.name}
      </h1>
    </div>
    <div class="reveal mb-3" data-delay="0.14">
      <p class="text-base text-accent-soft">{profile.roleTitle}</p>
    </div>
    <div class="reveal mb-8" data-delay="0.17">
      <p class="text-sm font-mono text-slate-500">{profile.location} · {profile.email} · {profile.whatsappDisplay}</p>
    </div>
    <div class="reveal flex flex-wrap gap-3" data-delay="0.22">
      <a
        href="/resume.pdf"
        download="Muhammed_Mubashir_V_CV.pdf"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-sm font-bold text-white transition-all hover:scale-[1.02] active:scale-[0.98]"
        style="background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 8px 30px rgba(37,99,235,0.45);"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" class="inline-block shrink-0"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Download CV PDF
      </a>
      <a
        href={profile.links.whatsapp}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors"
      >
        ↗ WhatsApp
      </a>
    </div>
  </div>
</section>

<section class="pb-16 px-4 section-border">
  <div class="mx-auto max-w-6xl pt-14">
    <div class="reveal glass-panel rounded-2xl p-8" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/60 mb-4">Professional Summary</p>
      <p class="text-base text-slate-300 leading-loose">{profile.summary}</p>
    </div>
  </div>
</section>

<section class="py-16 px-4 section-border">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-10" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-[0.3em] text-accent-soft/70 mb-3">Experience</p>
      <h2 class="font-display font-semibold text-white text-xl" style="letter-spacing: -0.02em;">Career History</h2>
    </div>
    <div class="space-y-5">
      {experience.map((item, i) => (
        <div class="reveal glass-panel rounded-2xl p-7" data-delay={String(0.05 + i * 0.06)}>
          <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
            <div>
              <h3 class="font-display font-semibold text-white">{item.role}</h3>
              <p class="text-sm text-accent-soft mt-1">{item.company} · {item.location}</p>
            </div>
            <span
              class="text-xs font-mono px-3 py-1 rounded-full shrink-0"
              style="border: 1px solid rgba(255,255,255,0.10); color: #5c6b80; background: rgba(255,255,255,0.03);"
            >
              {item.period}
            </span>
          </div>
          <ul class="space-y-2">
            {item.impact.map((point) => (
              <li class="text-sm text-slate-400 flex items-start gap-2.5">
                <span class="text-accent-soft/40 font-mono mt-0.5 shrink-0">-</span> {point}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-16 px-4 section-border">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-10" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-[0.3em] text-accent-soft/70 mb-3">Skills</p>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-2 mt-8">
      {skillGroups.map((group, i) => (
        <div class="reveal glass-panel rounded-2xl p-8 transition-all hover:border-accent-soft/30" data-delay={String(0.04 + i * 0.05)}>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-accent-soft/10 text-accent-soft">
              {i === 0 ? <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path></svg> : 
               i === 1 ? <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg> :
               i === 2 ? <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg> :
               <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>}
            </div>
            <h3 class="text-xs font-mono uppercase tracking-[0.2em] text-white/90">{group.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span
                class="text-xs px-3 py-1.5 rounded-full text-slate-400 font-mono transition-colors hover:text-white hover:bg-white/5"
                style="border: 1px solid rgba(255,255,255,0.07); background: rgba(255,255,255,0.02);"
              >
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-16 px-4 section-border">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-5 md:grid-cols-3">
      {education.map((item, i) => (
        <div class="reveal glass-panel rounded-2xl p-7" data-delay={String(0.05 + i * 0.07)}>
          <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/60 mb-3">Education</p>
          <h3 class="font-semibold text-white text-sm">{item.program}</h3>
          <p class="text-sm text-slate-400 mt-1">{item.institution}</p>
          <p class="text-xs font-mono text-slate-600 mt-2">{item.period}</p>
        </div>
      ))}
      <div class="reveal glass-panel rounded-2xl p-7" data-delay="0.20">
        <p class="text-xs font-mono uppercase tracking-widest text-accent-soft/60 mb-3">Languages</p>
        <div class="space-y-2">
          {profile.languages.map((lang) => (
            <div class="flex justify-between text-sm">
              <span class="text-slate-300">{lang.language}</span>
              <span class="text-slate-600 font-mono text-xs">{lang.proficiency}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-14 px-4 section-border">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-8" data-delay="0.05">
      <p class="text-xs font-mono uppercase tracking-[0.3em] text-accent-soft/70 mb-3">Role Fit</p>
      <p class="max-w-3xl text-sm text-slate-400 leading-loose">
        If you reached this page through searches around digital marketer, web developer, web-app developer, programmer, or AI systems specialist in Dubai,
        use the role pages below for the most direct service, proof, and identity context.
      </p>
    </div>
    <div class="reveal flex flex-wrap gap-3 mb-8" data-delay="0.08">
      <a href="/dubai-digital-marketer" class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors">
        Dubai Digital Marketer
      </a>
      <a href="/dubai-web-developer" class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors">
        Dubai Web Developer
      </a>
      <a href="/dubai-ai-engineer" class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors">
        Dubai AI Engineer
      </a>
      <a href="/generative-engine-optimization-specialist-dubai" class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors">
        GEO Specialist Dubai
      </a>
    </div>
    <div class="reveal flex flex-wrap gap-4" data-delay="0.05">
      <a
        href="/services"
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors"
      >
        Service Pages →
      </a>
      <a
        href="/resume.pdf"
        download="Muhammed_Mubashir_V_CV.pdf"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-bold text-white transition-all hover:scale-[1.02] active:scale-[0.98]"
        style="background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 4px 20px rgba(37,99,235,0.35);"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" class="inline-block shrink-0"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Download CV PDF
      </a>
      <a
        href={profile.links.whatsapp}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-medium text-slate-300 glass-panel ring-hover hover:text-white transition-colors"
      >
        ↗ WhatsApp
      </a>
    </div>
  </div>
</section>

</BaseLayout>
