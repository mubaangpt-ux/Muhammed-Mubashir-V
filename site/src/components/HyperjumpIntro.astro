---
// HyperjumpIntro.astro — Seamless Warp-to-Background Edition
// After the intro completes, the SAME canvas stays as the hero starfield.
// No canvas swap = no flash. Stars freeze at final positions with cursor ripple.
---

<canvas
  id="hj-canvas"
  aria-hidden="true"
  style="
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    will-change: opacity;
  "
></canvas>

<button
  id="hj-replay"
  aria-label="Replay intro"
  style="
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    opacity: 0.3;
    background: rgba(37,99,235,0.10);
    border: 1px solid rgba(147,197,253,0.20);
    color: #93c5fd;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: opacity 0.3s ease;
  "
  onmouseover="this.style.opacity='1'"
  onmouseout="this.style.opacity='0.3'"
>⟳ Replay</button>

<script is:inline>
(function () {
  'use strict';

  /* ═══════════════════════════════════════════════════════════════
     CONFIG — adjust anything here safely
     ═══════════════════════════════════════════════════════════════ */
  const C = {
    N:          1800,     // star count (same for intro AND hero background)

    // 3D projection
    FOCAL:       380,
    Z_FAR:      1500,
    Z_NEAR:        3,

    // Tunnel cylinder — stars sit ON this ring (forms the circular tunnel)
    R_INNER:      12,     // inner edge of ring (dark void inside this)
    R_OUTER:     150,     // outer edge

    // Phase timings (ms)
    T_IDLE:     1400,
    T_ACCEL:    1800,     // longer ramp = smoother
    T_HYPER:    1100,
    T_DECEL:    1600,     // longer ease-out = smoother
    T_FADE:     1200,     // canvas reposition fade

    // Speed (units/sec)
    V_SLOW:       22,
    V_FAST:     1500,

    // Motion blur persistence alpha
    BLUR_LO:    0.08,     // idle trail
    BLUR_HI:    0.86,     // full warp trail

    // Post-intro cursor ripple
    RIPPLE_R:    0.22,    // fraction of viewport
    RIPPLE_F:     14,     // push force in px
    SPRING:     0.05,     // return spring k

    // Star colours [R,G,B,maxAlpha]
    COLS: [
      [245, 248, 255, 0.92],
      [210, 228, 255, 0.78],
      [178, 210, 255, 0.70],
      [240, 244, 255, 0.85],
      [152, 192, 255, 0.60],
    ],

    BG: [7, 9, 15],
  };
  /* ═══════════════════════════════════════════════════════════════ */

  const canvas = document.getElementById('hj-canvas');
  const replay = document.getElementById('hj-replay');
  if (!canvas) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    canvas.style.display = 'none';
    document.body.classList.remove('hyperjump-active');
    revealHero(true);
    return;
  }

  const ctx = canvas.getContext('2d', { alpha: false });
  let W, H, cx, cy;

  /* ── Pre-allocated typed arrays (zero GC) ─── */
  const x3  = new Float32Array(C.N);
  const y3  = new Float32Array(C.N);
  const z   = new Float32Array(C.N);
  const ci  = new Uint8Array(C.N);      // colour index
  const bsz = new Float32Array(C.N);    // base size
  
  // Screen-space positions
  const sx  = new Float32Array(C.N);
  const sy  = new Float32Array(C.N);
  const psx = new Float32Array(C.N);
  const psy = new Float32Array(C.N);

  // Velocity for mouse interaction
  const vx  = new Float32Array(C.N);
  const vy  = new Float32Array(C.N);

  // Original target positions for background mode
  const tx  = new Float32Array(C.N);
  const ty  = new Float32Array(C.N);

  function initStar(i, randZ) {
    const ang = Math.random() * 6.2832;
    // Radial distribution: starts wide, but we'll tunnelize it via projection/bias
    const r   = 10 + Math.random() * 2000; 
    x3[i]     = Math.cos(ang) * r;
    y3[i]     = Math.sin(ang) * r;
    z[i]      = randZ ? Math.random() * C.Z_FAR + C.Z_NEAR : C.Z_FAR;
    ci[i]     = Math.random() * C.COLS.length | 0;
    bsz[i]    = Math.random() < 0.9 ? 0.4 + Math.random() * 0.7 : 0.9 + Math.random() * 1.5;
    
    vx[i] = vy[i] = 0;
  }

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W * 0.5;
    cy = H * 0.5;
    for (let i = 0; i < C.N; i++) initStar(i, true);
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`;
    ctx.fillRect(0, 0, W, H);
  }

  /* ── Easing ─── */
  const eIn  = t => t * t * t * t * t;
  const eOut = t => 1 - Math.pow(1 - t, 5);
  const lerp = (a, b, t) => a + (b - a) * t;
  const clamp= (v,lo,hi) => v < lo ? lo : v > hi ? hi : v;

  /* ── State ─── */
  let phase      = 'idle';    // idle | accel | hyper | decel | done
  let phaseStart = 0;
  let lastTs     = 0;
  let rafId      = null;
  let mouseX     = -9999, mouseY = -9999;
  let currentSpd = C.V_SLOW;

  function updatePhase(ts) {
    const elapsed = ts - phaseStart;
    if      (phase === 'idle'  && elapsed > C.T_IDLE)  { phase = 'accel'; phaseStart = ts; }
    else if (phase === 'accel' && elapsed > C.T_ACCEL) { phase = 'hyper'; phaseStart = ts; }
    else if (phase === 'hyper' && elapsed > C.T_HYPER) { phase = 'decel'; phaseStart = ts; }
    else if (phase === 'decel' && elapsed > C.T_DECEL) { phase = 'done';  phaseStart = ts; }
  }

  function getTargetSpeed(ts) {
    const e = ts - phaseStart;
    if (phase === 'idle')  return C.V_SLOW;
    if (phase === 'accel') return lerp(C.V_SLOW, C.V_FAST, eIn(clamp(e / C.T_ACCEL, 0, 1)));
    if (phase === 'hyper') return C.V_FAST;
    if (phase === 'decel') return lerp(C.V_FAST, C.V_SLOW, eOut(clamp(e / C.T_DECEL, 0, 1)));
    return 0;
  }

  /* ════════════════════════════════════════════════════════════════
     MAIN RENDER LOOP — UNIFIED
     ════════════════════════════════════════════════════════════════ */
  function frame(ts) {
    if (!lastTs) lastTs = ts;
    const dt = Math.min((ts - lastTs) / 1000, 0.05);
    lastTs = ts;

    updatePhase(ts);
    const targetSpd = getTargetSpeed(ts);
    currentSpd = lerp(currentSpd, targetSpd, 0.1); // smoothing speed transition

    const t01 = clamp((currentSpd - C.V_SLOW) / (C.V_FAST - C.V_SLOW), 0, 1);

    // ── Motion Blur ──
    const trailA = lerp(C.BLUR_LO, C.BLUR_HI, t01);
    ctx.fillStyle = `rgba(${C.BG[0]},${C.BG[1]},${C.BG[2]},${1 - trailA})`;
    ctx.fillRect(0, 0, W, H);

    // ── Warp Glow ──
    if (t01 > 0.05) {
      const gA = t01 * 0.15;
      const gR = Math.min(W, H) * 0.6 * t01;
      const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, gR);
      g.addColorStop(0,   `rgba(37,99,235,${gA})`);
      g.addColorStop(0.5, `rgba(20,55,180,${gA * 0.3})`);
      g.addColorStop(1,   'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, W, H);
    }

    // ── Projection Tuning ──
    // During warp, we narrow the "focal tunnel"
    const tunnelFactor = lerp(1.0, 0.15, eIn(t01));
    const dz = currentSpd * dt;

    for (let i = 0; i < C.N; i++) {
      if (phase !== 'done') {
        z[i] -= dz;
        if (z[i] < C.Z_NEAR) {
          initStar(i, false);
          continue;
        }
      }

      // 3D Projection with tunneling bias
      // In hyper mode, we push x/y toward the edges if they are too close to center
      const radialDist = Math.sqrt(x3[i] * x3[i] + y3[i] * y3[i]);
      const tunnelEffect = 1.0 + (t01 * 120.0 / Math.max(1, radialDist * 0.1));
      
      const sc  = (C.FOCAL / z[i]) * (1 + t01 * 2); 
      const x2  = cx + x3[i] * sc * (phase === 'done' ? 1 : tunnelEffect);
      const y2  = cy + y3[i] * sc * (phase === 'done' ? 1 : tunnelEffect);

      const prox = 1 - z[i] / C.Z_FAR;
      const [r, g, b, ma] = C.COLS[ci[i]];
      const a = clamp(ma * (0.1 + prox * 0.9), 0, 1);
      const s = bsz[i] * (0.5 + prox * 2.0);

      if (t01 > 0.05 && phase !== 'done') {
        ctx.beginPath();
        ctx.strokeStyle = `rgba(${r},${g},${b},${a})`;
        ctx.lineWidth   = Math.max(0.4, s * 0.5);
        ctx.moveTo(psx[i], psy[i]);
        ctx.lineTo(x2, y2);
        ctx.stroke();
      } else {
        ctx.beginPath();
        ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
        ctx.arc(x2, y2, Math.max(0.3, s * 0.45), 0, 6.2832);
        ctx.fill();
      }

      psx[i] = sx[i] = x2;
      psy[i] = sy[i] = y2;
    }

    if (phase === 'done') {
      const e = ts - phaseStart;
      const fadeT = clamp(e / C.T_FADE, 0, 1);

      if (fadeT >= 1) {
        // Handover to background interaction
        finishIntro();
        return;
      }
    }

    rafId = requestAnimationFrame(frame);
  }

  function finishIntro() {
    canvas.style.position = 'absolute';
    canvas.style.zIndex   = '0';
    const hero = document.querySelector('.hero-section');
    if (hero) {
      hero.style.position = 'relative';
      hero.insertBefore(canvas, hero.firstChild);
    }
    document.body.classList.remove('hyperjump-active');
    replay.style.display = 'block';

    // Record home for ripple
    for (let i = 0; i < C.N; i++) {
      tx[i] = sx[i]; ty[i] = sy[i];
    }
    
    revealHero(false);
    window.addEventListener('mousemove', onMouse, { passive: true });
    window.addEventListener('mouseleave', () => { mouseX = -9999; mouseY = -9999; }, { passive: true });
    
    rafId = requestAnimationFrame(bgLoop);
  }

  function bgLoop(ts) {
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`;
    ctx.fillRect(0, 0, W, H);

    const rect = canvas.getBoundingClientRect();
    const mxL = mouseX - rect.left;
    const myL = mouseY - rect.top;
    const ripR = C.RIPPLE_R * Math.min(W, H);
    const r2   = ripR * ripR;

    for (let i = 0; i < C.N; i++) {
      const dx = sx[i] - mxL;
      const dy = sy[i] - myL;
      const d2 = dx * dx + dy * dy;

      if (d2 < r2 && d2 > 1) {
        const t = 1 - d2 / r2;
        const inv = 1 / Math.sqrt(d2);
        const f = t * t * C.RIPPLE_F;
        vx[i] += dx * inv * f * 0.05;
        vy[i] += dy * inv * f * 0.05;
      }

      vx[i] += (tx[i] - sx[i]) * C.SPRING;
      vy[i] += (ty[i] - sy[i]) * C.SPRING;
      vx[i] *= 0.8; 
      vy[i] *= 0.8;
      sx[i] += vx[i];
      sy[i] += vy[i];

      const [r, g, b, ma] = C.COLS[ci[i]];
      ctx.beginPath();
      ctx.fillStyle = `rgba(${r},${g},${b},${ma * 0.7})`;
      ctx.arc(sx[i], sy[i], Math.max(0.3, bsz[i] * 0.6), 0, 6.2832);
      ctx.fill();
    }
    rafId = requestAnimationFrame(bgLoop);
  }

  function onMouse(e) { mouseX = e.clientX; mouseY = e.clientY; }

  function revealHero(instant) {
    const header = document.querySelector('header');
    if (header) {
      if (instant) header.classList.add('revealed');
      else setTimeout(() => header.classList.add('revealed'), 100);
    }

    const items = Array.from(document.querySelectorAll('.reveal'));
    items.forEach((el, i) => {
      if (instant) { el.classList.add('revealed'); return; }
      const d = el.dataset.delay ? parseFloat(el.dataset.delay) * 1000 : i * 110;
      setTimeout(() => el.classList.add('revealed'), 400 + d);
    });
  }

  function start() {
    canvas.style.position = 'fixed';
    canvas.style.zIndex   = '9999';
    canvas.style.display  = 'block';
    canvas.style.opacity  = '1';
    replay.style.display  = 'none';

    if (canvas.parentElement !== document.body) {
      document.body.insertBefore(canvas, document.body.firstChild);
    }

    document.body.classList.add('hyperjump-active');
    document.querySelectorAll('.reveal').forEach(el => el.classList.remove('revealed'));
    
    resize();
    phase = 'idle';
    phaseStart = lastTs = performance.now();
    currentSpd = C.V_SLOW;

    window.removeEventListener('mousemove', onMouse);
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(frame);
  }

  window.addEventListener('resize', () => {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W * 0.5;
    cy = H * 0.5;
  }, { passive: true });

  replay.addEventListener('click', start);
  start();
})();
</script>

<style is:global>
  body.hyperjump-active { overflow: hidden; }
  header { opacity: 0; transform: translateY(-20px); transition: all 0.9s cubic-bezier(0.2, 1, 0.3, 1); }
  header.revealed { opacity: 1; transform: none; }
  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1); will-change: opacity, transform; }
  .reveal.revealed { opacity: 1; transform: none; }
  
  .glass-panel.reveal, .glass-card.reveal, [class*="cap-card"].reveal, .metric-card.reveal {
     transform: translateY(40px) scale(0.95); transition: all 1s cubic-bezier(0.2, 1, 0.3, 1);
  }
  .glass-panel.reveal.revealed, .glass-card.reveal.revealed, [class*="cap-card"].reveal.revealed, .metric-card.reveal.revealed {
     transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    header, .reveal, .reveal.revealed { opacity: 1 !important; transform: none !important; transition: none !important; }
  }
</style>
