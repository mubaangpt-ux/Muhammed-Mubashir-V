  body.hyperjump-active { overflow: hidden; height: 100vh; }
  header { opacity: 0; transform: translateY(-14px); transition: opacity 1.35s cubic-bezier(0.22, 1, 0.36, 1), transform 1.35s cubic-bezier(0.22, 1, 0.36, 1); }
  header.revealed { opacity: 1; transform: none; }
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 1.45s cubic-bezier(0.22, 1, 0.36, 1), transform 1.65s cubic-bezier(0.22, 1, 0.36, 1); will-change: transform, opacity; }
  .reveal.revealed { opacity: 1; transform: none; }
  .glass-panel.reveal, .glass-card.reveal, [class*="cap-card"].reveal, .metric-card.reveal {
     transform: translateY(28px) scale(0.985); transition: opacity 1.55s cubic-bezier(0.22, 1, 0.36, 1), transform 1.75s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .glass-panel.reveal.revealed, .glass-card.reveal.revealed, [class*="cap-card"].reveal.revealed, .metric-card.reveal.revealed {
     transform: none;
  }
