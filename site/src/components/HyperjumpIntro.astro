---
// HyperjumpIntro.astro — Cinematic Warp Tunnel (Zero-GC Edition)
// Motion-blur technique: instead of per-star gradients (GC killer),
// we paint a semi-transparent black overlay each frame — creates natural
// fading trails (persistence of vision) with ZERO garbage allocation.
// Stars use 3D cylinder projection: fly out from a ring, dark void at center.
---

<canvas
  id="hj-canvas"
  aria-hidden="true"
  style="
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    will-change: opacity;
  "
></canvas>

<button
  id="hj-replay"
  aria-label="Replay intro"
  style="
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    opacity: 0.3;
    background: rgba(37,99,235,0.10);
    border: 1px solid rgba(147,197,253,0.20);
    color: #93c5fd;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: opacity 0.3s ease;
  "
  onmouseover="this.style.opacity='1'"
  onmouseout="this.style.opacity='0.3'"
>⟳ Replay</button>

<script is:inline>
(function () {
  'use strict';

  /* ═══════════════════════════════════════════════════════════════
     TUNING KNOBS — all safe to adjust
     ═══════════════════════════════════════════════════════════════ */
  const C = {
    // Stars
    N:         1800,   // star count (keep under 3000 for 60fps on mid hardware)
    FOCAL:      380,   // perspective focal length (larger = tighter zoom)
    Z_FAR:     1500,   // spawn depth
    Z_NEAR:       3,   // recycle when this close

    // Tunnel ring (3D radius of the cylinder stars orbit)
    R_INNER:      2,   // dark core radius (keep small — creates the void)
    R_OUTER:    140,   // outer ring radius

    // Phase durations in ms
    T_IDLE:    1400,   // calm drift
    T_ACCEL:   1600,   // ramp-up
    T_HYPER:   1100,   // full warp
    T_DECEL:   1400,   // ease back
    T_FADE:     900,   // canvas fade-out

    // Speed (world-units per second at 60fps — normalized by dt)
    V_SLOW:     22,    // idle drift speed
    V_FAST:   1600,    // peak hyperjump speed

    // Motion blur persistence (key to GC-free smooth trails)
    // 0.0 = no trail | 1.0 = persistent ghost
    BLUR_SLOW:  0.10,  // trail alpha at idle speed
    BLUR_FAST:  0.88,  // trail alpha at peak speed (long streaks)

    // Star colour palette [R, G, B, baseAlpha]
    COLORS: [
      [245, 248, 255, 0.92],   // near-white
      [210, 228, 255, 0.80],   // ice blue
      [180, 210, 255, 0.72],   // electric blue
      [240, 245, 255, 0.88],   // warm white
      [150, 190, 255, 0.62],   // deep blue
    ],

    BG: [7, 9, 15],            // #07090f as RGB for overlay
  };
  /* ═══════════════════════════════════════════════════════════════ */

  const canvas  = document.getElementById('hj-canvas');
  const replay  = document.getElementById('hj-replay');
  if (!canvas) return;

  // Reduced motion — skip intro
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    canvas.style.display = 'none';
    document.body.classList.remove('hyperjump-active');
    document.dispatchEvent(new CustomEvent('hyperjump-complete'));
    revealHero(true);
    return;
  }

  const ctx = canvas.getContext('2d', { alpha: false });
  let W, H, cx, cy;

  /* Pre-allocate star arrays (avoid object churn) */
  const sx3  = new Float32Array(C.N);   // 3D x
  const sy3  = new Float32Array(C.N);   // 3D y
  const sz   = new Float32Array(C.N);   // depth z
  const srnd = new Uint8Array(C.N);     // color index
  const ssz  = new Float32Array(C.N);   // base size
  const spx  = new Float32Array(C.N);   // prev screen x (for trails)
  const spy  = new Float32Array(C.N);   // prev screen y

  function initStar(i, spread) {
    const ang = Math.random() * 6.2832;
    const r   = C.R_INNER + Math.sqrt(Math.random()) * (C.R_OUTER - C.R_INNER);
    sx3[i] = Math.cos(ang) * r;
    sy3[i] = Math.sin(ang) * r;
    sz[i]  = spread
      ? Math.random() * C.Z_FAR + C.Z_NEAR
      : C.Z_FAR * (0.7 + Math.random() * 0.3);
    srnd[i]= Math.random() * C.COLORS.length | 0;
    ssz[i] = Math.random() < 0.88 ? 0.4 + Math.random() * 0.7 : 1.0 + Math.random() * 1.5;
    // seed prev positions to current to avoid first-frame streak
    const sc = C.FOCAL / sz[i];
    spx[i] = cx + sx3[i] * sc;
    spy[i] = cy + sy3[i] * sc;
  }

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W * 0.5;
    cy = H * 0.5;
    for (let i = 0; i < C.N; i++) initStar(i, true);
    // Clear to bg
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`;
    ctx.fillRect(0, 0, W, H);
  }

  /* ── Easing functions ─────────────────────────────────────────── */
  const eIn  = t => t * t * t * t;       // quartic ease-in
  const eOut = t => 1 - (1-t)*(1-t)*(1-t)*(1-t);
  const lerp = (a, b, t) => a + (b - a) * t;
  const clamp= (v,lo,hi) => v < lo ? lo : v > hi ? hi : v;

  /* ── Phase state ──────────────────────────────────────────────── */
  let phase      = 'idle';
  let phaseStart = 0;
  let lastTs     = 0;
  let rafId      = null;

  function getSpeed(ts) {
    const e = ts - phaseStart;
    if (phase === 'idle')  return C.V_SLOW;
    if (phase === 'accel') return lerp(C.V_SLOW, C.V_FAST, eIn(clamp(e / C.T_ACCEL, 0, 1)));
    if (phase === 'hyper') return C.V_FAST;
    if (phase === 'decel') return lerp(C.V_FAST, C.V_SLOW, eOut(clamp(e / C.T_DECEL, 0, 1)));
    return C.V_SLOW; // done
  }

  /* ── Main render loop ─────────────────────────────────────────── */
  function frame(ts) {
    const dt = Math.min((ts - lastTs) / 1000, 0.05); // cap at 50ms (20fps min)
    lastTs   = ts;
    const elapsed = ts - phaseStart;

    /* Phase transitions */
    if      (phase === 'idle'  && elapsed > C.T_IDLE)  { phase = 'accel'; phaseStart = ts; }
    else if (phase === 'accel' && elapsed > C.T_ACCEL) { phase = 'hyper'; phaseStart = ts; }
    else if (phase === 'hyper' && elapsed > C.T_HYPER) { phase = 'decel'; phaseStart = ts; }
    else if (phase === 'decel' && elapsed > C.T_DECEL) { phase = 'done';  phaseStart = ts; }

    const spd = getSpeed(ts);
    const t01 = clamp((spd - C.V_SLOW) / (C.V_FAST - C.V_SLOW), 0, 1); // 0=idle, 1=full warp

    /* ── Motion blur overlay (GC-FREE trail technique) ──
       Instead of per-star gradients, we simply paint a semi-transparent
       bg rectangle each frame. Stars leave "afterimage" trails naturally.
       The trail alpha scales from short (idle) to long (hyperjump).        */
    const trailAlpha = lerp(C.BLUR_SLOW, C.BLUR_FAST, t01 * t01);
    ctx.fillStyle = `rgba(${C.BG[0]},${C.BG[1]},${C.BG[2]},${1 - trailAlpha})`;
    ctx.fillRect(0, 0, W, H);

    /* ── Ambient blue tunnel glow (during warp) ─── */
    if (t01 > 0.08) {
      const glowA = t01 * 0.22;
      const gR    = Math.min(W, H) * 0.55 * t01;
      const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, gR);
      g.addColorStop(0,    `rgba(37,99,235,${glowA})`);
      g.addColorStop(0.5,  `rgba(20,55,180,${glowA * 0.4})`);
      g.addColorStop(1,    'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, W, H);
    }

    /* ── Star movement & draw ─── */
    const dz = spd * dt;   // depth change this frame (dt-normalized)

    for (let i = 0; i < C.N; i++) {
      sz[i] -= dz;

      if (sz[i] < C.Z_NEAR) {
        initStar(i, false);   // recycle from far
        continue;
      }

      const sc  = C.FOCAL / sz[i];
      const x2d = cx + sx3[i] * sc;
      const y2d = cy + sy3[i] * sc;

      const prox  = 1 - sz[i] / C.Z_FAR;    // 0=far, 1=close
      const [r,g,b,ma] = C.COLORS[srnd[i]];
      const alpha = clamp(ma * (0.15 + prox * 0.9), 0, 1);
      const ptSz  = ssz[i] * (0.5 + prox * 2.2);

      // At warp speed: draw line from spx/spy → x2d/y2d (motion blur trail adds the streak naturally)
      if (t01 > 0.05 && (spx[i] !== x2d || spy[i] !== y2d)) {
        ctx.beginPath();
        ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
        ctx.lineWidth   = Math.max(0.5, ptSz * 0.5);
        ctx.moveTo(spx[i], spy[i]);
        ctx.lineTo(x2d, y2d);
        ctx.stroke();
      } else {
        // Slow drift: crisp dot
        ctx.beginPath();
        ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
        ctx.arc(x2d, y2d, Math.max(0.3, ptSz * 0.45), 0, 6.2832);
        ctx.fill();
      }

      spx[i] = x2d;
      spy[i] = y2d;
    }

    /* ── Dark void at centre (tunnel mouth ring) ─── */
    if (t01 > 0.12) {
      const vR = 20 + t01 * 35;
      const v  = ctx.createRadialGradient(cx, cy, 0, cx, cy, vR * 3);
      v.addColorStop(0,    `rgba(5,7,14,${t01 * 0.96})`);
      v.addColorStop(0.35, `rgba(7,9,15,${t01 * 0.60})`);
      v.addColorStop(1,    'rgba(0,0,0,0)');
      ctx.fillStyle = v;
      ctx.fillRect(0, 0, W, H);
    }

    /* ── Fade-out & reveal ─── */
    if (phase === 'done') {
      const fadeT = clamp(elapsed / C.T_FADE, 0, 1);
      canvas.style.opacity = (1 - fadeT).toString();

      if (fadeT >= 1) {
        canvas.style.display = 'none';
        replay.style.display = 'block';
        document.body.classList.remove('hyperjump-active');
        document.dispatchEvent(new CustomEvent('hyperjump-complete'));
        revealHero(false);
        cancelAnimationFrame(rafId);
        rafId = null;
        return;
      }
    }

    rafId = requestAnimationFrame(frame);
  }

  /* ── Staggered hero reveal ────────────────────────────────────── */
  function revealHero(instant) {
    // Header first
    const header = document.querySelector('header');
    if (header) {
      header.classList.add('reveal');
      if (!instant) {
        requestAnimationFrame(() => setTimeout(() => header.classList.add('revealed'), 60));
      } else {
        header.classList.add('revealed');
      }
    }

    // All .reveal elements — use their data-delay or index-based stagger
    const items = Array.from(document.querySelectorAll('.reveal:not(header)'));
    items.forEach((el, i) => {
      const delay = parseFloat(el.dataset.delay || 0) * 1000 || i * 90;
      if (instant) {
        el.classList.add('revealed');
      } else {
        setTimeout(() => el.classList.add('revealed'), 220 + delay);
      }
    });
  }

  /* ── Boot / Replay ────────────────────────────────────────────── */
  function start() {
    canvas.style.display = 'block';
    canvas.style.opacity = '1';
    replay.style.display = 'none';
    document.body.classList.add('hyperjump-active');

    // Reset reveal state for replay
    document.querySelectorAll('.reveal').forEach(el => el.classList.remove('revealed'));
    const header = document.querySelector('header');
    if (header) header.classList.remove('revealed');

    resize();

    phase      = 'idle';
    phaseStart = performance.now();
    lastTs     = phaseStart;

    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(frame);
  }

  window.addEventListener('resize', resize, { passive: true });
  replay.addEventListener('click', start);
  start();
})();
</script>

<style is:global>
  /* Body lock during intro */
  body.hyperjump-active {
    overflow: hidden;
  }

  /* ── Header reveal ── */
  header {
    opacity: 0;
    transform: translateY(-12px);
    transition:
      opacity  0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  header.revealed {
    opacity: 1;
    transform: none;
  }

  /* ── Hero element reveal ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity  0.75s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }
  .reveal.revealed {
    opacity: 1;
    transform: none;
  }

  /* ── Glass cards extra: scale-in from slightly below ── */
  .glass-panel.reveal,
  .glass-card.reveal,
  [class*="cap-card"].reveal,
  .metric-card.reveal {
    transform: translateY(32px) scale(0.97);
    transition:
      opacity  0.80s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.80s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .glass-panel.reveal.revealed,
  .glass-card.reveal.revealed,
  [class*="cap-card"].reveal.revealed,
  .metric-card.reveal.revealed {
    transform: none;
  }

  /* No animations for reduced motion users */
  @media (prefers-reduced-motion: reduce) {
    header,
    .reveal,
    .reveal.revealed {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
