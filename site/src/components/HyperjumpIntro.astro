---
// HyperjumpIntro.astro — Ultra-Realistic 3D Warp Tunnel
// Stars spawn in a 3D cylindrical ring to ensure the "loop" void in the center.
// Unified engine: no canvas swap or frame resets between intro and background.
---

<canvas
  id="hj-canvas"
  aria-hidden="true"
  style="
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    will-change: opacity;
  "
></canvas>

<button
  id="hj-replay"
  aria-label="Replay intro"
  style="
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    opacity: 0.3;
    background: rgba(37,99,235,0.10);
    border: 1px solid rgba(147,197,253,0.20);
    color: #93c5fd;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: opacity 0.3s ease;
  "
  onmouseover="this.style.opacity='1'"
  onmouseout="this.style.opacity='0.3'"
>⟳ Replay</button>

<script>
  (() => {
  if (window.__hjRuntime?.handlePageLoad) {
    return;
  }
  const runtime = window.__hjRuntime = window.__hjRuntime || {};
  /* ═══════════════════════════════════════════════════════════════
     CONFIG & PERSISTENT STATE
     ═══════════════════════════════════════════════════════════════ */
  const C = {
    N:          2200,
    FOCAL:       380,
    Z_FAR:      1600,
    Z_NEAR:        3,
    R_INNER:      22,     // sharper hole
    R_OUTER:     180,     
    T_IDLE:     1000,
    T_ACCEL:    2000,
    T_HYPER:    1000,
    T_DECEL:    2200,
    T_FADE:     1200,
    V_SLOW:       15,
    V_FAST:     1650,
    BLUR_LO:    0.06,
    BLUR_HI:    0.90,
    RIPPLE_R:    0.28,
    RIPPLE_F:     18,
    SPRING:     0.05,
    BG_SEED:  0x4d554241,
    COLS: [
      [255, 255, 255, 1.0], [147, 197, 253, 0.9],
      [59, 130, 246, 0.8], [219, 234, 254, 0.95]
    ],
    BG: [7, 9, 15]
  };
  const BG_SNAPSHOT_KEY = 'hj_background_snapshot_v2';
  const EXTERNAL_LANDING_KEY = 'hj_external_landing_intro_seen';
  const BG_POS_SCALE = 100000;
  const BG_SIZE_SCALE = 1000;
  const BG_ALPHA_SCALE = 1000;

  // Persistent engine state (survives client-side navigation)
  let canvas, ctx, replay, W, H, cx, cy;
  let DPR = 1;
  let rafId = null, lastTs = 0, phaseStart = 0;
  let phase = 'idle', mode = 'intro', curSpd = C.V_SLOW, expFactor = 1.0;
  let mouseX = -9999, mouseY = -9999;
  let initialized = false;
  let backgroundPrepared = false;
  let bgEventsBound = false;
  let backgroundSnapshot = null;
  let revealTimers = [];
  let starCount = C.N;
  let staticBackgroundMode = false;
  let lowPowerMode = false;
  let backgroundFrameInterval = 1000 / 45;
  let lastBgFrame = 0;
  let homeMediaWarmStarted = false;
  let touchRippleUntil = 0;

  const HERO_REVEAL_SELECTORS = [
    '.hero-orbit-stage',
    '.hero-portrait-layer',
    '.hero-content-shade',
    '.hero-pill-reveal',
    '.hero-name-stack',
    '.hero-glow-baseline',
    '.hero-role-reveal',
    '.hero-discipline-reveal',
    '.hero-cta-reveal',
    '.hero-social-proof',
  ];

  const x3 = new Float32Array(C.N), y3 = new Float32Array(C.N), z3 = new Float32Array(C.N);
  const ci = new Uint8Array(C.N), bsz = new Float32Array(C.N);
  const sx = new Float32Array(C.N), sy = new Float32Array(C.N), psx = new Float32Array(C.N), psy = new Float32Array(C.N);
  const hx = new Float32Array(C.N), hy = new Float32Array(C.N), vx = new Float32Array(C.N), vy = new Float32Array(C.N);
  const sa = new Float32Array(C.N), sr = new Float32Array(C.N);
  const tw = new Float32Array(C.N);

  function detectPerformanceProfile() {
    const coarsePointer = window.matchMedia('(pointer: coarse)').matches || window.matchMedia('(hover: none)').matches;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const memory = navigator.deviceMemory || 8;
    const cores = navigator.hardwareConcurrency || 8;
    const narrowViewport = Math.min(window.innerWidth, window.innerHeight) < 768;

    lowPowerMode = reducedMotion || memory <= 4 || cores <= 4 || narrowViewport;
    staticBackgroundMode = reducedMotion || coarsePointer;
    starCount = staticBackgroundMode ? 700 : lowPowerMode ? 1200 : C.N;
    backgroundFrameInterval = staticBackgroundMode ? 1000 / 18 : lowPowerMode ? 1000 / 30 : 1000 / 45;
  }

  function createSeededRandom(seed) {
    let state = seed >>> 0;
    return () => {
      state = (state * 1664525 + 1013904223) >>> 0;
      return state / 4294967296;
    };
  }

  function initStar(i, randZ, random = Math.random) {
    const tunnel = random() < 0.75;
    const a = random() * 6.2831;
    const r = tunnel ? C.R_INNER + random() * (C.R_OUTER - C.R_INNER) : random() * (C.R_OUTER * 15);
    x3[i] = Math.cos(a) * r; y3[i] = Math.sin(a) * r;
    z3[i] = randZ ? random() * C.Z_FAR + C.Z_NEAR : C.Z_FAR * (0.8 + random() * 0.2);
    ci[i] = random() * C.COLS.length | 0;
    bsz[i] = (random() < 0.9 ? 0.4 + random() * 0.6 : 1.0 + random() * 1.5) * (tunnel ? 1 : 0.65);
    vx[i] = vy[i] = 0;
    sa[i] = C.COLS[ci[i]][3];
    sr[i] = Math.max(0.35, bsz[i] * 0.6);
    tw[i] = random() * 6.2831;
    const psc = C.FOCAL / z3[i]; 
    const px = x3[i] * psc + (W / 2);
    const py = y3[i] * psc + (H / 2);
    psx[i] = sx[i] = hx[i] = px; 
    psy[i] = sy[i] = hy[i] = py;
  }

  function resetIntroScene() {
    for (let i = 0; i < starCount; i++) initStar(i, true);
    backgroundPrepared = false;
  }

  function loadBackgroundSnapshot() {
    if (backgroundSnapshot) return backgroundSnapshot;
    try {
      const raw = sessionStorage.getItem(BG_SNAPSHOT_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (!parsed || (parsed.v !== 2 && parsed.v !== 3)) return null;
      if (!Array.isArray(parsed.x) || !Array.isArray(parsed.y) || !Array.isArray(parsed.s) || !Array.isArray(parsed.c)) return null;
      if (parsed.x.length < starCount || parsed.y.length < starCount || parsed.s.length < starCount || parsed.c.length < starCount) return null;
      if (parsed.a && (!Array.isArray(parsed.a) || parsed.a.length < starCount)) return null;
      backgroundSnapshot = parsed;
      return backgroundSnapshot;
    } catch {
      return null;
    }
  }

  function saveBackgroundSnapshot() {
    const snapshot = {
      v: 3,
      n: starCount,
      x: Array.from({ length: starCount }, (_, i) => Math.round((hx[i] / W) * BG_POS_SCALE)),
      y: Array.from({ length: starCount }, (_, i) => Math.round((hy[i] / H) * BG_POS_SCALE)),
      s: Array.from({ length: starCount }, (_, i) => Math.round(sr[i] * BG_SIZE_SCALE)),
      a: Array.from({ length: starCount }, (_, i) => Math.round(sa[i] * BG_ALPHA_SCALE)),
      c: Array.from(ci.slice(0, starCount)),
    };
    backgroundSnapshot = snapshot;
    try {
      sessionStorage.setItem(BG_SNAPSHOT_KEY, JSON.stringify(snapshot));
    } catch {}
  }

  function restoreBackgroundSnapshot(snapshot = loadBackgroundSnapshot()) {
    if (!snapshot) return false;
    const legacySnapshot = snapshot.v === 2;
    for (let i = 0; i < starCount; i++) {
      const px = (snapshot.x[i] / BG_POS_SCALE) * W;
      const py = (snapshot.y[i] / BG_POS_SCALE) * H;
      hx[i] = sx[i] = psx[i] = px;
      hy[i] = sy[i] = psy[i] = py;
      x3[i] = px - cx;
      y3[i] = py - cy;
      z3[i] = C.Z_FAR * 0.86;
      const colorIndex = Number.isInteger(snapshot.c[i]) ? snapshot.c[i] : 0;
      const storedSize = Math.max(0.35, (snapshot.s[i] || 450) / BG_SIZE_SCALE);
      bsz[i] = storedSize;
      sr[i] = legacySnapshot ? Math.max(0.35, storedSize * 0.6) : storedSize;
      sa[i] = Array.isArray(snapshot.a)
        ? Math.min(1, Math.max(0.12, (snapshot.a[i] || 700) / BG_ALPHA_SCALE))
        : C.COLS[colorIndex][3] * 0.7;
      ci[i] = colorIndex;
      tw[i] = (i * 0.61803398875) % 6.2831;
      vx[i] = vy[i] = 0;
    }
    backgroundPrepared = true;
    return true;
  }

  function freezeCurrentBackgroundFrame() {
    for (let i = 0; i < starCount; i++) {
      hx[i] = sx[i];
      hy[i] = sy[i];
      psx[i] = sx[i];
      psy[i] = sy[i];
      x3[i] = sx[i] - cx;
      y3[i] = sy[i] - cy;
      vx[i] = vy[i] = 0;
    }
    backgroundPrepared = true;
  }

  function clearRevealTimers() {
    revealTimers.forEach((timerId) => clearTimeout(timerId));
    revealTimers = [];
  }

  function shouldUseStaticHomeReveal() {
    return (
      window.matchMedia('(pointer: coarse)').matches ||
      window.matchMedia('(hover: none)').matches ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(max-width: 767px)').matches
    );
  }

  function warmHomeMedia() {
    if (homeMediaWarmStarted || !isHomeRoute()) return;
    homeMediaWarmStarted = true;

    const mediaUrls = new Set(['/profile.png']);

    document.querySelectorAll('img[src]').forEach((node) => {
      const src = node.getAttribute('src');
      if (src && src.startsWith('/')) mediaUrls.add(src);
    });

    document.querySelectorAll('video[poster], video[data-src]').forEach((node) => {
      const poster = node.getAttribute('poster');
      const src = node.getAttribute('data-src');
      if (poster && poster.startsWith('/')) mediaUrls.add(poster);
      if (src && src.startsWith('/')) mediaUrls.add(src);
    });

    const warmList = Array.from(mediaUrls).slice(0, 24);
    const schedule = window.requestIdleCallback || ((cb) => window.setTimeout(cb, 120));
    schedule(() => {
      warmList.forEach((url) => {
        if (/\.(mp4|webm|ogg)$/i.test(url)) {
          const link = document.createElement('link');
          link.rel = 'preload';
          link.as = 'video';
          link.href = url;
          document.head.appendChild(link);
          return;
        }

        const img = new Image();
        img.decoding = 'async';
        img.loading = 'eager';
        if ('fetchPriority' in img) img.fetchPriority = 'high';
        img.src = url;
      });
    }, { timeout: 1200 });
  }

  function prepareBackgroundScene() {
    const random = createSeededRandom(C.BG_SEED);
    const wideX = W * 0.94;
    const wideY = H * 0.78;
    const orbitRadius = Math.min(W, H) * 0.46;

    for (let i = 0; i < starCount; i++) {
      const layer = random();
      let px;
      let py;

      if (layer < 0.58) {
        px = random() * W;
        py = random() * H;
      } else if (layer < 0.88) {
        px = cx + (random() - 0.5) * wideX;
        py = cy + (random() - 0.5) * wideY;
      } else {
        const angle = random() * 6.2831;
        const radius = Math.pow(random(), 0.72) * orbitRadius;
        px = cx + Math.cos(angle) * radius * 1.28;
        py = cy + Math.sin(angle) * radius * 0.92;
      }

      const baseX = Math.min(Math.max(px, -W * 0.08), W * 1.08);
      const baseY = Math.min(Math.max(py, -H * 0.08), H * 1.08);
      hx[i] = sx[i] = psx[i] = baseX;
      hy[i] = sy[i] = psy[i] = baseY;
      x3[i] = hx[i] - cx;
      y3[i] = hy[i] - cy;
      z3[i] = C.Z_FAR * (0.78 + random() * 0.18);
      ci[i] = random() * C.COLS.length | 0;
      bsz[i] = layer < 0.2
        ? 0.35 + random() * 0.65
        : layer < 0.82
          ? 0.25 + random() * 0.55
          : 0.5 + random() * 0.9;
      sr[i] = Math.max(0.35, bsz[i] * 0.6);
      sa[i] = C.COLS[ci[i]][3] * 0.7;
      tw[i] = random() * 6.2831;
      vx[i] = vy[i] = 0;
    }
    backgroundPrepared = true;
  }

  let bgCanvas = null;
  let starSpriteCache = new Map();

  function getStarSprite(colorIndex, radius, alpha) {
    const [r, g, b] = C.COLS[colorIndex];
    const bucketRadius = Math.max(0.35, Math.round(radius * 4) / 4);
    const bucketAlpha = Math.max(0.12, Math.round(alpha * 12) / 12);
    const key = `${colorIndex}:${bucketRadius}:${bucketAlpha}:${DPR}`;

    if (starSpriteCache.has(key)) return starSpriteCache.get(key);

    const glowRadius = Math.max(2.3, bucketRadius * 3.05);
    const logicalSize = Math.max(8, Math.ceil(glowRadius * 2 + 4));
    const sprite = document.createElement('canvas');
    sprite.width = Math.ceil(logicalSize * DPR);
    sprite.height = Math.ceil(logicalSize * DPR);

    const sCtx = sprite.getContext('2d');
    sCtx.setTransform(DPR, 0, 0, DPR, 0, 0);
    sCtx.imageSmoothingEnabled = true;
    const mid = logicalSize / 2;
    const gradient = sCtx.createRadialGradient(mid, mid, 0, mid, mid, glowRadius);
    gradient.addColorStop(0, `rgba(${r},${g},${b},${bucketAlpha})`);
    gradient.addColorStop(0.38, `rgba(${r},${g},${b},${bucketAlpha * 0.62})`);
    gradient.addColorStop(1, `rgba(${r},${g},${b},0)`);
    sCtx.fillStyle = gradient;
    sCtx.beginPath();
    sCtx.arc(mid, mid, glowRadius, 0, Math.PI * 2);
    sCtx.fill();

    sCtx.fillStyle = `rgba(${r},${g},${b},${Math.min(1, bucketAlpha * 1.08)})`;
    sCtx.beginPath();
    sCtx.arc(mid, mid, Math.max(0.55, bucketRadius), 0, Math.PI * 2);
    sCtx.fill();

    const payload = { canvas: sprite, size: logicalSize };
    starSpriteCache.set(key, payload);
    return payload;
  }

  function drawStarDot(x, y, colorIndex, radius, alpha) {
    const sprite = getStarSprite(colorIndex, radius, alpha);
    const offset = sprite.size * 0.5;
    ctx.drawImage(sprite.canvas, x - offset, y - offset, sprite.size, sprite.size);
  }

  function drawWarpStreak(x0, y0, x1, y1, colorIndex, radius, alpha, warpStrength) {
    const [r, g, b] = C.COLS[colorIndex];
    const dx = x1 - x0;
    const dy = y1 - y0;
    const len = Math.hypot(dx, dy);

    if (len < 1.4) {
      drawStarDot(x1, y1, colorIndex, radius, alpha);
      return;
    }

    const nx = dx / len;
    const ny = dy / len;
    const tail = Math.min(len, lerp(6, 46, warpStrength) + radius * 5.8);
    const sx0 = x1 - nx * tail;
    const sy0 = y1 - ny * tail;
    const innerTail = Math.min(tail * 0.74, tail - 2);
    const sx1 = x1 - nx * innerTail;
    const sy1 = y1 - ny * innerTail;

    ctx.save();
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.strokeStyle = `rgba(${r},${g},${b},${alpha * 0.1})`;
    ctx.lineWidth = Math.max(0.8, radius * 2.1);
    ctx.moveTo(sx0, sy0);
    ctx.lineTo(x1, y1);
    ctx.stroke();

    ctx.beginPath();
    ctx.strokeStyle = `rgba(${r},${g},${b},${alpha * 0.28})`;
    ctx.lineWidth = Math.max(0.5, radius * 0.95);
    ctx.moveTo(sx1, sy1);
    ctx.lineTo(x1, y1);
    ctx.stroke();
    ctx.restore();

    drawStarDot(x1, y1, colorIndex, Math.max(radius, 0.38 + warpStrength * 0.36), Math.min(1, alpha * 1.02));
  }

  function prepareCachedBackdrop() {
    if (!bgCanvas) bgCanvas = document.createElement('canvas');
    bgCanvas.width = Math.round(W * DPR);
    bgCanvas.height = Math.round(H * DPR);
    const bCtx = bgCanvas.getContext('2d', { alpha: false });
    bCtx.setTransform(DPR, 0, 0, DPR, 0, 0);
    bCtx.imageSmoothingEnabled = true;
    
    bCtx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`;
    bCtx.fillRect(0, 0, W, H);

    const centerField = bCtx.createRadialGradient(cx, H * 0.42, 0, cx, H * 0.42, Math.max(W * 0.54, H * 0.84));
    centerField.addColorStop(0, 'rgba(16,54,138,0.52)');
    centerField.addColorStop(0.42, 'rgba(10,38,104,0.34)');
    centerField.addColorStop(0.72, 'rgba(6,20,64,0.18)');
    centerField.addColorStop(1, 'rgba(6,20,64,0)');
    bCtx.fillStyle = centerField;
    bCtx.fillRect(0, 0, W, H);

    const upperHalo = bCtx.createRadialGradient(cx, H * 0.12, 0, cx, H * 0.18, Math.max(W * 0.38, H * 0.42));
    upperHalo.addColorStop(0, 'rgba(37,99,235,0.22)');
    upperHalo.addColorStop(0.45, 'rgba(37,99,235,0.12)');
    upperHalo.addColorStop(1, 'rgba(37,99,235,0)');
    bCtx.fillStyle = upperHalo;
    bCtx.fillRect(0, 0, W, H);

    const leftVignette = bCtx.createLinearGradient(0, 0, W * 0.24, 0);
    leftVignette.addColorStop(0, 'rgba(0,0,0,0.96)');
    leftVignette.addColorStop(0.28, 'rgba(1,4,14,0.82)');
    leftVignette.addColorStop(1, 'rgba(1,4,14,0)');
    bCtx.fillStyle = leftVignette;
    bCtx.fillRect(0, 0, W, H);

    const rightVignette = bCtx.createLinearGradient(W, 0, W * 0.76, 0);
    rightVignette.addColorStop(0, 'rgba(0,0,0,0.96)');
    rightVignette.addColorStop(0.28, 'rgba(1,4,14,0.82)');
    rightVignette.addColorStop(1, 'rgba(1,4,14,0)');
    bCtx.fillStyle = rightVignette;
    bCtx.fillRect(0, 0, W, H);

    const verticalVignette = bCtx.createLinearGradient(0, 0, 0, H);
    verticalVignette.addColorStop(0, 'rgba(1,6,18,0.44)');
    verticalVignette.addColorStop(0.18, 'rgba(1,6,18,0.16)');
    verticalVignette.addColorStop(0.65, 'rgba(1,6,18,0)');
    verticalVignette.addColorStop(1, 'rgba(0,0,0,0.44)');
    bCtx.fillStyle = verticalVignette;
    bCtx.fillRect(0, 0, W, H);

    const bottomDepth = bCtx.createRadialGradient(cx, H * 1.02, 0, cx, H * 1.02, Math.max(W * 0.66, H * 0.56));
    bottomDepth.addColorStop(0, 'rgba(2,8,23,0.60)');
    bottomDepth.addColorStop(0.7, 'rgba(2,8,23,0.22)');
    bottomDepth.addColorStop(1, 'rgba(2,8,23,0)');
    bCtx.fillStyle = bottomDepth;
    bCtx.fillRect(0, 0, W, H);
  }

  function drawBackgroundBackdrop(alpha = 1) {
    if (!bgCanvas) prepareCachedBackdrop();
    if (alpha !== 1) {
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.drawImage(bgCanvas, 0, 0);
      ctx.restore();
    } else {
      ctx.drawImage(bgCanvas, 0, 0);
    }
  }

  function mountBackgroundCanvas() {
    canvas.style.position = 'fixed';
    canvas.style.inset = '0';
    canvas.style.width = '100vw';
    canvas.style.height = '100vh';
    canvas.style.zIndex = '0';
    if (canvas.parentElement !== document.body) {
      document.body.insertBefore(canvas, document.body.firstChild);
    }
  }

  function onMouseLeave() {
    mouseX = -9999;
    mouseY = -9999;
  }

  function wakeBackgroundRipple(clientX, clientY) {
    mouseX = clientX;
    mouseY = clientY;
    touchRippleUntil = performance.now() + 720;

    if (mode !== 'background') return;
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(bgLoop);
  }

  function onPointerDown(e) {
    if (e.pointerType === 'mouse' && staticBackgroundMode) return;
    wakeBackgroundRipple(e.clientX, e.clientY);
  }

  function onPointerMove(e) {
    if (e.pointerType && e.pointerType !== 'mouse') return;
    if (staticBackgroundMode) return;
    mouseX = e.clientX;
    mouseY = e.clientY;
    touchRippleUntil = 0;

    if (mode !== 'background' || rafId) return;
    rafId = requestAnimationFrame(bgLoop);
  }

  function onTouchStart(e) {
    const touch = e.touches && e.touches[0];
    if (!touch) return;
    wakeBackgroundRipple(touch.clientX, touch.clientY);
  }

  function bindBackgroundEvents() {
    if (bgEventsBound) return;
    // Desktop keeps the responsive hover field, while touch devices stay on the
    // lighter tap-based ripple path to preserve smoothness on mobile.
    window.addEventListener('pointermove', onPointerMove, { passive: true });
    window.addEventListener('pointerdown', onPointerDown, { passive: true });
    window.addEventListener('touchstart', onTouchStart, { passive: true });
    window.addEventListener('pointerleave', onMouseLeave, { passive: true });
    bgEventsBound = true;
  }

  function resize() {
    detectPerformanceProfile();
    DPR = Math.min(window.devicePixelRatio || 1, staticBackgroundMode ? 1.35 : lowPowerMode ? 1.6 : 2);
    W = window.innerWidth; H = window.innerHeight;
    canvas.width = Math.round(W * DPR);
    canvas.height = Math.round(H * DPR);
    canvas.style.width = `${W}px`;
    canvas.style.height = `${H}px`;
    cx = W * 0.5; cy = H * 0.5;
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    ctx.imageSmoothingEnabled = true;
    starSpriteCache.clear();
    prepareCachedBackdrop();
    if (!initialized) {
      resetIntroScene();
      initialized = true;
    } else if (mode === 'background' && backgroundPrepared) {
      if (!restoreBackgroundSnapshot()) {
        prepareBackgroundScene();
        saveBackgroundSnapshot();
      }
    }
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`; ctx.fillRect(0, 0, W, H);
    if (mode === 'background' && staticBackgroundMode) {
      bgLoop(performance.now());
    }
  }

  const eIn = t => t * t * t * t * t, eOut = t => 1 - Math.pow(1 - t, 5);
  const lerp = (a, b, t) => a + (b - a) * t, clamp = (v, lo, hi) => v < lo ? lo : v > hi ? hi : v;

  function frame(ts) {
    if (!lastTs) lastTs = ts;
    const dt = Math.min((ts - lastTs) / 1000, 0.05); lastTs = ts;
    const el = ts - phaseStart;

    if (phase === 'idle' && el > C.T_IDLE) { phase = 'accel'; phaseStart = ts; }
    else if (phase === 'accel' && el > C.T_ACCEL) { phase = 'hyper'; phaseStart = ts; }
    else if (phase === 'hyper' && el > C.T_HYPER) { phase = 'decel'; phaseStart = ts; }
    else if (phase === 'decel' && el > C.T_DECEL) { phase = 'done'; phaseStart = ts; }

    const accelT = clamp(el / C.T_ACCEL, 0, 1);
    const decelT = clamp(el / C.T_DECEL, 0, 1);
    const hyperPulse = phase === 'hyper' ? 0.94 + Math.sin(el * 0.018) * 0.06 : 1;
    const target = (phase === 'idle')
      ? C.V_SLOW
      : (phase === 'accel')
        ? lerp(C.V_SLOW, C.V_FAST, eIn(accelT))
        : (phase === 'hyper')
          ? C.V_FAST * hyperPulse
          : (phase === 'decel')
            ? lerp(C.V_FAST, C.V_SLOW, eOut(decelT))
            : 0;
    curSpd = lerp(curSpd, target, phase === 'hyper' ? 0.2 : 0.15);
    const t01 = clamp((curSpd - C.V_SLOW) / (C.V_FAST - C.V_SLOW), 0, 1);
    const driftX = Math.sin(ts * 0.00036) * lerp(0.4, 1.6, t01);
    const driftY = Math.cos(ts * 0.00042) * lerp(0.3, 1.2, t01);

    ctx.fillStyle = `rgba(${C.BG[0]},${C.BG[1]},${C.BG[2]},${1 - lerp(C.BLUR_LO, C.BLUR_HI, t01)})`; ctx.fillRect(0, 0, W, H);

    if (phase === 'decel' || phase === 'done') {
      const alpha = clamp(el / (phase === 'decel' ? C.T_DECEL : C.T_FADE), 0, 1);
      drawBackgroundBackdrop(alpha);
    }

    expFactor = (phase === 'decel' || phase === 'done') ? 1.0 + eOut(el / C.T_DECEL) * 6.0 : 1.0;
    const dz = curSpd * dt;

    for (let i = 0; i < starCount; i++) {
      if (phase !== 'done') {
        z3[i] -= dz; if (z3[i] < C.Z_NEAR) { 
          initStar(i, false); const sc2 = C.FOCAL / z3[i]; psx[i] = cx + x3[i]*sc2*expFactor; psy[i] = cy + y3[i]*sc2*expFactor; 
        }
      }
      const sc = C.FOCAL / z3[i], x = cx + driftX + x3[i]*sc*expFactor, y = cy + driftY + y3[i]*sc*expFactor;
      const p = 1 - z3[i] / C.Z_FAR, [r, g, b, ma] = C.COLS[ci[i]], twinkle = 0.94 + Math.sin(ts * 0.0022 + tw[i]) * (phase === 'hyper' ? 0.03 : 0.08), a = clamp(ma * twinkle * (0.15 + p * 0.85), 0, 1), s = bsz[i] * (0.6 + p * 1.82);
      const fillAlpha = a * (mode === 'background' ? 0.7 : 1);
      sa[i] = fillAlpha;
      sr[i] = Math.max(0.32, s * 0.45);
      if (t01 > 0.05 && phase !== 'done') {
        drawWarpStreak(psx[i], psy[i], x, y, ci[i], sr[i], fillAlpha, t01);
      } else {
        drawStarDot(x, y, ci[i], sr[i], fillAlpha);
      }
      psx[i] = x; psy[i] = y; sx[i] = x; sy[i] = y;
    }

    if (phase === 'done' && clamp(el / C.T_FADE, 0, 1) >= 1 && mode === 'intro') {
      sessionStorage.setItem('hj_intro_played', 'true'); finishIntro(); return;
    }
    rafId = requestAnimationFrame(frame);
  }

  function finishIntro(wasSkipped) {
    if (!canvas) return;
    if (wasSkipped) {
      if (!restoreBackgroundSnapshot()) {
        prepareBackgroundScene();
        saveBackgroundSnapshot();
      }
    } else {
      freezeCurrentBackgroundFrame();
      saveBackgroundSnapshot();
    }
    syncBackground('none');
    if (!wasSkipped) revealHero(false);
  }

  function bgLoop(ts) {
    if (document.hidden) {
      rafId = requestAnimationFrame(bgLoop);
      return;
    }

    if (lastBgFrame && ts - lastBgFrame < backgroundFrameInterval) {
      rafId = requestAnimationFrame(bgLoop);
      return;
    }
    lastBgFrame = ts;

    drawBackgroundBackdrop();

    const r = canvas.getBoundingClientRect();
    const mxL = mouseX - r.left, myL = mouseY - r.top, r2 = (C.RIPPLE_R * Math.min(W, H)) ** 2;
    const rippleActive = ts < touchRippleUntil;
    const hoverActive = !staticBackgroundMode && mouseX > -9000 && mouseY > -9000;
    const hoverR2 = Math.max(180, Math.min(W, H) * 0.18) ** 2;
    let maxMotion = 0;
    for (let i = 0; i < starCount; i++) {
        const dx = sx[i] - mxL, dy = sy[i] - myL, d2 = dx*dx + dy*dy;
        if (rippleActive && d2 < r2 && d2 > 0.1) {
            const t = 1 - d2/r2, f = t*t*C.RIPPLE_F, inv = 1/Math.sqrt(d2);
            vx[i] += dx*inv*f*0.05; vy[i] += dy*inv*f*0.05;
        } else if (hoverActive && d2 < hoverR2 && d2 > 0.1) {
            const t = 1 - d2/hoverR2;
            const inv = 1/Math.sqrt(d2);
            const f = t*t*1.15;
            vx[i] += dx*inv*f*0.024; vy[i] += dy*inv*f*0.024;
        }
        vx[i] += (hx[i] - sx[i]) * C.SPRING; vy[i] += (hy[i] - sy[i]) * C.SPRING;
        vx[i] *= 0.8; vy[i] *= 0.8; sx[i] += vx[i]; sy[i] += vy[i];
        const displacement = Math.abs(hx[i] - sx[i]) + Math.abs(hy[i] - sy[i]);
        const velocity = Math.abs(vx[i]) + Math.abs(vy[i]);
        if (displacement + velocity > maxMotion) maxMotion = displacement + velocity;
        const shimmer = sa[i] * (0.9 + Math.sin(ts * 0.0016 + tw[i]) * 0.1);
        drawStarDot(sx[i], sy[i], ci[i], sr[i], shimmer);
    }
    if (rippleActive || hoverActive || maxMotion > 0.18) {
      rafId = requestAnimationFrame(bgLoop);
    } else {
      rafId = null;
      onMouseLeave();
    }
  }

  function scheduleReveal(el, delay) {
    if (!el) return;
    const timerId = window.setTimeout(() => el.classList.add('revealed'), delay);
    revealTimers.push(timerId);
  }

  function revealImmediately(selectors) {
    selectors.forEach((selector) => {
      document.querySelectorAll(selector).forEach((el) => el.classList.add('revealed'));
    });
  }

  function revealAllNonHeroContent() {
    document.querySelectorAll('.reveal').forEach((el) => {
      if (!el.closest('.hero-section')) {
        el.classList.add('revealed');
      }
    });
  }

  function revealHeaderImmediately() {
    const header = document.querySelector('header');
    if (header) header.classList.add('revealed');
  }

  function revealHomeImmediately() {
    revealHeaderImmediately();
    revealImmediately(HERO_REVEAL_SELECTORS);
    if (shouldUseStaticHomeReveal()) {
      revealAllNonHeroContent();
    }
  }

  function revealHero(wasSkipped) {
    const fastMode = Boolean(wasSkipped);
    const header = document.querySelector('header');
    if (header) {
      scheduleReveal(header, fastMode ? 120 : 200);
    }

    const hero = document.querySelector('.hero-section');
    if (!hero) {
      document.querySelectorAll('.reveal').forEach((el, i) => {
        scheduleReveal(el, (fastMode ? 200 : 320) + i * (fastMode ? 55 : 90));
      });
      return;
    }

    scheduleReveal(document.querySelector('.hero-orbit-stage'), fastMode ? 360 : 780);
    const portraitBeatDelay = fastMode ? 620 : 1260;
    scheduleReveal(document.querySelector('.hero-portrait-layer'), portraitBeatDelay);
    scheduleReveal(document.querySelector('.hero-content-shade'), portraitBeatDelay);

    const copyGroups = [
      ['.hero-pill-reveal'],
      ['.hero-name-stack', '.hero-glow-baseline'],
      ['.hero-role-reveal'],
      ['.hero-discipline-reveal'],
      ['.hero-cta-reveal'],
      ['.hero-social-proof'],
    ];
    const copyStart = fastMode ? 820 : 1700;
    const copyStagger = fastMode ? 130 : 210;

    copyGroups.forEach((selectors, index) => {
      const delay = copyStart + index * copyStagger;
      selectors.forEach((selector) => scheduleReveal(document.querySelector(selector), delay));
    });
  }

  function syncBackground(revealMode = 'none') {
    if (!canvas) return;
    mode = 'background';
    mountBackgroundCanvas();
    if (!restoreBackgroundSnapshot()) {
      if (!backgroundPrepared) prepareBackgroundScene();
      saveBackgroundSnapshot();
    }
    canvas.style.display = 'block';
    canvas.style.opacity = '1';
    canvas.style.pointerEvents = 'none';
    document.body.classList.remove('hyperjump-active');
    if (replay) replay.style.display = 'block';

    if (revealMode === 'hero') revealHomeImmediately();
    else if (revealMode === 'header') revealHeaderImmediately();

    bindBackgroundEvents();
    document.dispatchEvent(new CustomEvent('hyperjump-complete'));
    if (rafId) cancelAnimationFrame(rafId);
    lastBgFrame = 0;
    if (staticBackgroundMode) {
      bgLoop(performance.now());
      return;
    }
    rafId = requestAnimationFrame(bgLoop);
  }

  function isHomeRoute() {
    return window.location.pathname === '/' || window.location.pathname.endsWith('/index.html');
  }

  function isExternalReferrer() {
    try {
      if (!document.referrer) return false;
      const referrer = new URL(document.referrer);
      return referrer.origin !== window.location.origin;
    } catch {
      return false;
    }
  }

  function startIntro() {
    canvas = document.getElementById('hj-canvas'); replay = document.getElementById('hj-replay');
    if (!canvas) return;
    detectPerformanceProfile();
    ctx = canvas.getContext('2d', { alpha: false });
    resize();
    clearRevealTimers();
    warmHomeMedia();

    canvas.style.position = 'fixed'; canvas.style.zIndex = '9999'; canvas.style.display = 'block'; canvas.style.opacity = '1';
    if (canvas.parentElement !== document.body) document.body.insertBefore(canvas, document.body.firstChild);
    document.body.classList.add('hyperjump-active');
    const header = document.querySelector('header');
    if (header) header.classList.remove('revealed');
    HERO_REVEAL_SELECTORS.forEach((selector) => {
      document.querySelectorAll(selector).forEach((el) => el.classList.remove('revealed'));
    });
    
    resetIntroScene();
    mode = 'intro'; phase = 'idle'; phaseStart = lastTs = performance.now(); curSpd = C.V_SLOW;
    if (rafId) cancelAnimationFrame(rafId); rafId = requestAnimationFrame(frame);
  }

  function handlePageLoad() {
    canvas = document.getElementById('hj-canvas');
    replay = document.getElementById('hj-replay');
    if (!canvas) return;

    detectPerformanceProfile();
    ctx = canvas.getContext('2d', { alpha: false });
    resize();
    clearRevealTimers();

    const played = sessionStorage.getItem('hj_intro_played');
    const isHome = isHomeRoute();
    const hasBooted = Boolean(runtime.hasBooted);
    const shouldReplayForExternalLanding =
      !hasBooted &&
      isHome &&
      isExternalReferrer() &&
      !sessionStorage.getItem(EXTERNAL_LANDING_KEY);
    runtime.hasBooted = true;

    if (isHome) {
      warmHomeMedia();
    }

    if (shouldReplayForExternalLanding) {
      sessionStorage.setItem(EXTERNAL_LANDING_KEY, 'true');
      sessionStorage.removeItem('hj_intro_played');
      startIntro();
      return;
    }

    if (!hasBooted && isHome && !played) {
      startIntro();
      return;
    }

    syncBackground(isHome ? 'hero' : 'header');
  }

  runtime.handlePageLoad = handlePageLoad;

  document.addEventListener('astro:page-load', () => {
    if (!window.hj_ev) { window.addEventListener('resize', () => { if(canvas) resize(); }, { passive: true }); window.hj_ev = true; }
    handlePageLoad();
  });
  document.addEventListener('astro:after-swap', () => {
    if (rafId) cancelAnimationFrame(rafId);
    clearRevealTimers();
  });
  document.addEventListener('click', (e) => {
    if (e.target.id === 'hj-replay') {
      sessionStorage.removeItem('hj_intro_played');
      sessionStorage.removeItem(EXTERNAL_LANDING_KEY);
      sessionStorage.removeItem(BG_SNAPSHOT_KEY);
      backgroundSnapshot = null;
      runtime.hasBooted = false;
      handlePageLoad();
    }
  });
  })();
</script>

