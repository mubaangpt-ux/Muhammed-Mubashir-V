---
// HyperjumpIntro.astro — Ultra-Realistic 3D Warp Tunnel
// Stars spawn in a 3D cylindrical ring to ensure the "loop" void in the center.
// Unified engine: no canvas swap or frame resets between intro and background.
---

<canvas
  id="hj-canvas"
  aria-hidden="true"
  style="
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    will-change: opacity;
  "
></canvas>

<button
  id="hj-replay"
  aria-label="Replay intro"
  style="
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    opacity: 0.3;
    background: rgba(37,99,235,0.10);
    border: 1px solid rgba(147,197,253,0.20);
    color: #93c5fd;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: opacity 0.3s ease;
  "
  onmouseover="this.style.opacity='1'"
  onmouseout="this.style.opacity='0.3'"
>⟳ Replay</button>

<script>
  /* ═══════════════════════════════════════════════════════════════
     CONFIG & PERSISTENT STATE
     ═══════════════════════════════════════════════════════════════ */
  const C = {
    N:          3500,
    FOCAL:       380,
    Z_FAR:      1600,
    Z_NEAR:        3,
    R_INNER:      22,     // sharper hole
    R_OUTER:     180,     
    T_IDLE:     1000,
    T_ACCEL:    2000,
    T_HYPER:    1000,
    T_DECEL:    2200,
    T_FADE:     1200,
    V_SLOW:       15,
    V_FAST:     1650,
    BLUR_LO:    0.06,
    BLUR_HI:    0.90,
    RIPPLE_R:    0.28,
    RIPPLE_F:     18,
    SPRING:     0.05,
    BG_SEED:  0x4d554241,
    COLS: [
      [255, 255, 255, 1.0], [147, 197, 253, 0.9],
      [59, 130, 246, 0.8], [219, 234, 254, 0.95]
    ],
    BG: [7, 9, 15]
  };
  const BG_SNAPSHOT_KEY = 'hj_background_snapshot_v1';
  const BG_POS_SCALE = 100000;
  const BG_SIZE_SCALE = 1000;
  const BG_ALPHA_SCALE = 1000;

  // Persistent engine state (survives client-side navigation)
  let canvas, ctx, replay, W, H, cx, cy;
  let rafId = null, lastTs = 0, phaseStart = 0;
  let phase = 'idle', mode = 'intro', curSpd = C.V_SLOW, expFactor = 1.0;
  let mouseX = -9999, mouseY = -9999;
  let initialized = false;
  let backgroundPrepared = false;
  let bgEventsBound = false;
  let backgroundSnapshot = null;
  let revealTimers = [];

  const x3 = new Float32Array(C.N), y3 = new Float32Array(C.N), z3 = new Float32Array(C.N);
  const ci = new Uint8Array(C.N), bsz = new Float32Array(C.N);
  const sx = new Float32Array(C.N), sy = new Float32Array(C.N), psx = new Float32Array(C.N), psy = new Float32Array(C.N);
  const hx = new Float32Array(C.N), hy = new Float32Array(C.N), vx = new Float32Array(C.N), vy = new Float32Array(C.N);
  const sa = new Float32Array(C.N), sr = new Float32Array(C.N);

  function createSeededRandom(seed) {
    let state = seed >>> 0;
    return () => {
      state = (state * 1664525 + 1013904223) >>> 0;
      return state / 4294967296;
    };
  }

  function initStar(i, randZ, random = Math.random) {
    const tunnel = random() < 0.75;
    const a = random() * 6.2831;
    const r = tunnel ? C.R_INNER + random() * (C.R_OUTER - C.R_INNER) : random() * (C.R_OUTER * 15);
    x3[i] = Math.cos(a) * r; y3[i] = Math.sin(a) * r;
    z3[i] = randZ ? random() * C.Z_FAR + C.Z_NEAR : C.Z_FAR * (0.8 + random() * 0.2);
    ci[i] = random() * C.COLS.length | 0;
    bsz[i] = (random() < 0.9 ? 0.4 + random() * 0.6 : 1.0 + random() * 1.5) * (tunnel ? 1 : 0.65);
    vx[i] = vy[i] = 0;
    sa[i] = C.COLS[ci[i]][3];
    sr[i] = Math.max(0.35, bsz[i] * 0.6);
    const psc = C.FOCAL / z3[i]; 
    const px = x3[i] * psc + (W / 2);
    const py = y3[i] * psc + (H / 2);
    psx[i] = sx[i] = hx[i] = px; 
    psy[i] = sy[i] = hy[i] = py;
  }

  function resetIntroScene() {
    for (let i = 0; i < C.N; i++) initStar(i, true);
    backgroundPrepared = false;
  }

  function loadBackgroundSnapshot() {
    if (backgroundSnapshot) return backgroundSnapshot;
    try {
      const raw = sessionStorage.getItem(BG_SNAPSHOT_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (!parsed || (parsed.v !== 1 && parsed.v !== 2)) return null;
      if (!Array.isArray(parsed.x) || !Array.isArray(parsed.y) || !Array.isArray(parsed.s) || !Array.isArray(parsed.c)) return null;
      if (parsed.x.length !== C.N || parsed.y.length !== C.N || parsed.s.length !== C.N || parsed.c.length !== C.N) return null;
      if (parsed.a && (!Array.isArray(parsed.a) || parsed.a.length !== C.N)) return null;
      backgroundSnapshot = parsed;
      return backgroundSnapshot;
    } catch {
      return null;
    }
  }

  function saveBackgroundSnapshot() {
    const snapshot = {
      v: 2,
      x: Array.from({ length: C.N }, (_, i) => Math.round((hx[i] / W) * BG_POS_SCALE)),
      y: Array.from({ length: C.N }, (_, i) => Math.round((hy[i] / H) * BG_POS_SCALE)),
      s: Array.from({ length: C.N }, (_, i) => Math.round(sr[i] * BG_SIZE_SCALE)),
      a: Array.from({ length: C.N }, (_, i) => Math.round(sa[i] * BG_ALPHA_SCALE)),
      c: Array.from(ci),
    };
    backgroundSnapshot = snapshot;
    try {
      sessionStorage.setItem(BG_SNAPSHOT_KEY, JSON.stringify(snapshot));
    } catch {}
  }

  function restoreBackgroundSnapshot(snapshot = loadBackgroundSnapshot()) {
    if (!snapshot) return false;
    const legacySnapshot = snapshot.v === 1;
    for (let i = 0; i < C.N; i++) {
      const px = (snapshot.x[i] / BG_POS_SCALE) * W;
      const py = (snapshot.y[i] / BG_POS_SCALE) * H;
      hx[i] = sx[i] = psx[i] = px;
      hy[i] = sy[i] = psy[i] = py;
      x3[i] = px - cx;
      y3[i] = py - cy;
      z3[i] = C.Z_FAR * 0.86;
      const colorIndex = Number.isInteger(snapshot.c[i]) ? snapshot.c[i] : 0;
      const storedSize = Math.max(0.35, (snapshot.s[i] || 450) / BG_SIZE_SCALE);
      bsz[i] = storedSize;
      sr[i] = legacySnapshot ? Math.max(0.35, storedSize * 0.6) : storedSize;
      sa[i] = Array.isArray(snapshot.a)
        ? Math.min(1, Math.max(0.12, (snapshot.a[i] || 700) / BG_ALPHA_SCALE))
        : C.COLS[colorIndex][3] * 0.7;
      ci[i] = colorIndex;
      vx[i] = vy[i] = 0;
    }
    backgroundPrepared = true;
    return true;
  }

  function freezeCurrentBackgroundFrame() {
    for (let i = 0; i < C.N; i++) {
      hx[i] = sx[i];
      hy[i] = sy[i];
      psx[i] = sx[i];
      psy[i] = sy[i];
      x3[i] = sx[i] - cx;
      y3[i] = sy[i] - cy;
      vx[i] = vy[i] = 0;
    }
    backgroundPrepared = true;
  }

  function clearRevealTimers() {
    revealTimers.forEach((timerId) => clearTimeout(timerId));
    revealTimers = [];
  }

  function prepareBackgroundScene() {
    const random = createSeededRandom(C.BG_SEED);
    const wideX = W * 0.94;
    const wideY = H * 0.78;
    const orbitRadius = Math.min(W, H) * 0.46;

    for (let i = 0; i < C.N; i++) {
      const layer = random();
      let px;
      let py;

      if (layer < 0.58) {
        px = random() * W;
        py = random() * H;
      } else if (layer < 0.88) {
        px = cx + (random() - 0.5) * wideX;
        py = cy + (random() - 0.5) * wideY;
      } else {
        const angle = random() * 6.2831;
        const radius = Math.pow(random(), 0.72) * orbitRadius;
        px = cx + Math.cos(angle) * radius * 1.28;
        py = cy + Math.sin(angle) * radius * 0.92;
      }

      const baseX = Math.min(Math.max(px, -W * 0.08), W * 1.08);
      const baseY = Math.min(Math.max(py, -H * 0.08), H * 1.08);
      hx[i] = sx[i] = psx[i] = baseX;
      hy[i] = sy[i] = psy[i] = baseY;
      x3[i] = hx[i] - cx;
      y3[i] = hy[i] - cy;
      z3[i] = C.Z_FAR * (0.78 + random() * 0.18);
      ci[i] = random() * C.COLS.length | 0;
      bsz[i] = layer < 0.2
        ? 0.35 + random() * 0.65
        : layer < 0.82
          ? 0.25 + random() * 0.55
          : 0.6 + random() * 1.2;
      sr[i] = Math.max(0.35, bsz[i] * 0.6);
      sa[i] = C.COLS[ci[i]][3] * 0.7;
      vx[i] = vy[i] = 0;
    }
    backgroundPrepared = true;
  }

  let bgCanvas = null;

  function prepareCachedBackdrop() {
    if (!bgCanvas) bgCanvas = document.createElement('canvas');
    bgCanvas.width = W; bgCanvas.height = H;
    const bCtx = bgCanvas.getContext('2d', { alpha: false });
    
    bCtx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`;
    bCtx.fillRect(0, 0, W, H);

    const centerField = bCtx.createRadialGradient(cx, H * 0.42, 0, cx, H * 0.42, Math.max(W * 0.54, H * 0.84));
    centerField.addColorStop(0, 'rgba(16,54,138,0.52)');
    centerField.addColorStop(0.42, 'rgba(10,38,104,0.34)');
    centerField.addColorStop(0.72, 'rgba(6,20,64,0.18)');
    centerField.addColorStop(1, 'rgba(6,20,64,0)');
    bCtx.fillStyle = centerField;
    bCtx.fillRect(0, 0, W, H);

    const upperHalo = bCtx.createRadialGradient(cx, H * 0.12, 0, cx, H * 0.18, Math.max(W * 0.38, H * 0.42));
    upperHalo.addColorStop(0, 'rgba(37,99,235,0.22)');
    upperHalo.addColorStop(0.45, 'rgba(37,99,235,0.12)');
    upperHalo.addColorStop(1, 'rgba(37,99,235,0)');
    bCtx.fillStyle = upperHalo;
    bCtx.fillRect(0, 0, W, H);

    const leftVignette = bCtx.createLinearGradient(0, 0, W * 0.24, 0);
    leftVignette.addColorStop(0, 'rgba(0,0,0,0.96)');
    leftVignette.addColorStop(0.28, 'rgba(1,4,14,0.82)');
    leftVignette.addColorStop(1, 'rgba(1,4,14,0)');
    bCtx.fillStyle = leftVignette;
    bCtx.fillRect(0, 0, W, H);

    const rightVignette = bCtx.createLinearGradient(W, 0, W * 0.76, 0);
    rightVignette.addColorStop(0, 'rgba(0,0,0,0.96)');
    rightVignette.addColorStop(0.28, 'rgba(1,4,14,0.82)');
    rightVignette.addColorStop(1, 'rgba(1,4,14,0)');
    bCtx.fillStyle = rightVignette;
    bCtx.fillRect(0, 0, W, H);

    const verticalVignette = bCtx.createLinearGradient(0, 0, 0, H);
    verticalVignette.addColorStop(0, 'rgba(1,6,18,0.44)');
    verticalVignette.addColorStop(0.18, 'rgba(1,6,18,0.16)');
    verticalVignette.addColorStop(0.65, 'rgba(1,6,18,0)');
    verticalVignette.addColorStop(1, 'rgba(0,0,0,0.44)');
    bCtx.fillStyle = verticalVignette;
    bCtx.fillRect(0, 0, W, H);

    const bottomDepth = bCtx.createRadialGradient(cx, H * 1.02, 0, cx, H * 1.02, Math.max(W * 0.66, H * 0.56));
    bottomDepth.addColorStop(0, 'rgba(2,8,23,0.60)');
    bottomDepth.addColorStop(0.7, 'rgba(2,8,23,0.22)');
    bottomDepth.addColorStop(1, 'rgba(2,8,23,0)');
    bCtx.fillStyle = bottomDepth;
    bCtx.fillRect(0, 0, W, H);
  }

  function drawBackgroundBackdrop(alpha = 1) {
    if (!bgCanvas) prepareCachedBackdrop();
    if (alpha !== 1) {
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.drawImage(bgCanvas, 0, 0);
      ctx.restore();
    } else {
      ctx.drawImage(bgCanvas, 0, 0);
    }
  }

  function mountBackgroundCanvas() {
    canvas.style.position = 'fixed';
    canvas.style.inset = '0';
    canvas.style.width = '100vw';
    canvas.style.height = '100vh';
    canvas.style.zIndex = '0';
    if (canvas.parentElement !== document.body) {
      document.body.insertBefore(canvas, document.body.firstChild);
    }
  }

  function onMouseLeave() {
    mouseX = -9999;
    mouseY = -9999;
  }

  function bindBackgroundEvents() {
    if (bgEventsBound) return;
    window.addEventListener('mousemove', onMouse, { passive: true });
    window.addEventListener('mouseleave', onMouseLeave, { passive: true });
    bgEventsBound = true;
  }

  function resize() {
    W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight;
    cx = W * 0.5; cy = H * 0.5;
    prepareCachedBackdrop();
    if (!initialized) {
      resetIntroScene();
      initialized = true;
    } else if (mode === 'background' && backgroundPrepared) {
      if (!restoreBackgroundSnapshot()) {
        prepareBackgroundScene();
        saveBackgroundSnapshot();
      }
    }
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`; ctx.fillRect(0, 0, W, H);
  }

  const eIn = t => t * t * t * t * t, eOut = t => 1 - Math.pow(1 - t, 5);
  const lerp = (a, b, t) => a + (b - a) * t, clamp = (v, lo, hi) => v < lo ? lo : v > hi ? hi : v;

  function frame(ts) {
    if (!lastTs) lastTs = ts;
    const dt = Math.min((ts - lastTs) / 1000, 0.05); lastTs = ts;
    const el = ts - phaseStart;

    if (phase === 'idle' && el > C.T_IDLE) { phase = 'accel'; phaseStart = ts; }
    else if (phase === 'accel' && el > C.T_ACCEL) { phase = 'hyper'; phaseStart = ts; }
    else if (phase === 'hyper' && el > C.T_HYPER) { phase = 'decel'; phaseStart = ts; }
    else if (phase === 'decel' && el > C.T_DECEL) { phase = 'done'; phaseStart = ts; }

    const target = (phase === 'idle') ? C.V_SLOW : (phase === 'accel') ? lerp(C.V_SLOW, C.V_FAST, eIn(clamp(el/C.T_ACCEL,0,1))) : (phase === 'hyper') ? C.V_FAST : (phase === 'decel') ? lerp(C.V_FAST, C.V_SLOW, eOut(clamp(el/C.T_DECEL,0,1))) : 0;
    curSpd = lerp(curSpd, target, 0.15);
    const t01 = clamp((curSpd - C.V_SLOW) / (C.V_FAST - C.V_SLOW), 0, 1);

    ctx.fillStyle = `rgba(${C.BG[0]},${C.BG[1]},${C.BG[2]},${1 - lerp(C.BLUR_LO, C.BLUR_HI, t01)})`; ctx.fillRect(0, 0, W, H);

    if (phase === 'decel' || phase === 'done') {
      const alpha = clamp(el / (phase === 'decel' ? C.T_DECEL : C.T_FADE), 0, 1);
      drawBackgroundBackdrop(alpha);
    }

    expFactor = (phase === 'decel' || phase === 'done') ? 1.0 + eOut(el / C.T_DECEL) * 6.0 : 1.0;
    const dz = curSpd * dt;

    for (let i = 0; i < C.N; i++) {
      if (phase !== 'done') {
        z3[i] -= dz; if (z3[i] < C.Z_NEAR) { 
          initStar(i, false); const sc2 = C.FOCAL / z3[i]; psx[i] = cx + x3[i]*sc2*expFactor; psy[i] = cy + y3[i]*sc2*expFactor; 
        }
      }
      const sc = C.FOCAL / z3[i], x = cx + x3[i]*sc*expFactor, y = cy + y3[i]*sc*expFactor;
      const p = 1 - z3[i] / C.Z_FAR, [r, g, b, ma] = C.COLS[ci[i]], a = clamp(ma*(0.15+p*0.85),0,1), s = bsz[i]*(0.6+p*1.8);
      const fillAlpha = a * (mode === 'background' ? 0.7 : 1);
      sa[i] = fillAlpha;
      sr[i] = Math.max(0.35, s * 0.45);
      if (t01 > 0.05 && phase !== 'done') {
        ctx.beginPath(); ctx.strokeStyle = `rgba(${r},${g},${b},${a})`; ctx.lineWidth = Math.max(0.6, s*0.5);
        ctx.moveTo(psx[i], psy[i]); ctx.lineTo(x, y); ctx.stroke();
      } else {
        ctx.fillStyle = `rgba(${r},${g},${b},${fillAlpha})`;
        const sSize = sr[i] * 2;
        ctx.fillRect(x - sr[i], y - sr[i], sSize, sSize);
      }
      psx[i] = x; psy[i] = y; sx[i] = x; sy[i] = y;
    }

    if (phase === 'done' && clamp(el / C.T_FADE, 0, 1) >= 1 && mode === 'intro') {
      sessionStorage.setItem('hj_intro_played', 'true'); finishIntro(); return;
    }
    rafId = requestAnimationFrame(frame);
  }

  function finishIntro(wasSkipped) {
    if (!canvas) return;
    mode = 'background';
    mountBackgroundCanvas();
    if (wasSkipped) {
      if (!restoreBackgroundSnapshot()) {
        prepareBackgroundScene();
        saveBackgroundSnapshot();
      }
    } else {
      freezeCurrentBackgroundFrame();
      saveBackgroundSnapshot();
    }
    canvas.style.display = 'block'; 
    canvas.style.opacity = '1';
    canvas.style.pointerEvents = 'none';
    document.body.classList.remove('hyperjump-active');
    if (replay) replay.style.display = 'block';
    
    revealHero(wasSkipped);
    bindBackgroundEvents();
    document.dispatchEvent(new CustomEvent('hyperjump-complete'));
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(bgLoop);
  }

  function bgLoop(ts) {
    drawBackgroundBackdrop();

    const r = canvas.getBoundingClientRect();
    const mxL = mouseX - r.left, myL = mouseY - r.top, r2 = (C.RIPPLE_R * Math.min(W, H)) ** 2;
    for (let i = 0; i < C.N; i++) {
        const dx = sx[i] - mxL, dy = sy[i] - myL, d2 = dx*dx + dy*dy;
        if (d2 < r2 && d2 > 0.1) {
            const t = 1 - d2/r2, f = t*t*C.RIPPLE_F, inv = 1/Math.sqrt(d2);
            vx[i] += dx*inv*f*0.05; vy[i] += dy*inv*f*0.05;
        }
        vx[i] += (hx[i] - sx[i]) * C.SPRING; vy[i] += (hy[i] - sy[i]) * C.SPRING;
        vx[i] *= 0.8; vy[i] *= 0.8; sx[i] += vx[i]; sy[i] += vy[i];
        const [rc, gc, bc] = C.COLS[ci[i]];
        ctx.fillStyle = `rgba(${rc},${gc},${bc},${sa[i]})`;
        const sSize = sr[i] * 2;
        ctx.fillRect(sx[i] - sr[i], sy[i] - sr[i], sSize, sSize);
    }
    rafId = requestAnimationFrame(bgLoop);
  }

  function onMouse(e) { mouseX = e.clientX; mouseY = e.clientY; }

  function scheduleReveal(el, delay) {
    if (!el) return;
    const timerId = window.setTimeout(() => el.classList.add('revealed'), delay);
    revealTimers.push(timerId);
  }

  function revealHero(wasSkipped) {
    const fastMode = Boolean(wasSkipped);
    const header = document.querySelector('header');
    if (header) {
      scheduleReveal(header, fastMode ? 120 : 200);
    }

    const hero = document.querySelector('.hero-section');
    if (!hero) {
      document.querySelectorAll('.reveal').forEach((el, i) => {
        scheduleReveal(el, (fastMode ? 200 : 320) + i * (fastMode ? 55 : 90));
      });
      return;
    }

    scheduleReveal(document.querySelector('.hero-orbit-stage'), fastMode ? 360 : 780);
    const portraitBeatDelay = fastMode ? 620 : 1260;
    scheduleReveal(document.querySelector('.hero-portrait-layer'), portraitBeatDelay);
    scheduleReveal(document.querySelector('.hero-content-shade'), portraitBeatDelay);

    const copyGroups = [
      ['.hero-pill-reveal'],
      ['.hero-name-stack', '.hero-glow-baseline'],
      ['.hero-role-reveal'],
      ['.hero-discipline-reveal'],
      ['.hero-cta-reveal'],
      ['.hero-social-proof'],
    ];
    const copyStart = fastMode ? 820 : 1700;
    const copyStagger = fastMode ? 130 : 210;

    copyGroups.forEach((selectors, index) => {
      const delay = copyStart + index * copyStagger;
      selectors.forEach((selector) => scheduleReveal(document.querySelector(selector), delay));
    });
  }

  function start() {
    canvas = document.getElementById('hj-canvas'); replay = document.getElementById('hj-replay');
    if (!canvas) return; ctx = canvas.getContext('2d', { alpha: false }); resize();
    clearRevealTimers();
    
    const played = sessionStorage.getItem('hj_intro_played'), isHome = window.location.pathname === '/' || window.location.pathname.endsWith('/index.html');
    if (played || !isHome) { finishIntro(true); return; }

    canvas.style.position = 'fixed'; canvas.style.zIndex = '9999'; canvas.style.display = 'block'; canvas.style.opacity = '1';
    if (canvas.parentElement !== document.body) document.body.insertBefore(canvas, document.body.firstChild);
    document.body.classList.add('hyperjump-active');
    const header = document.querySelector('header');
    if (header) header.classList.remove('revealed');
    document.querySelectorAll('.reveal').forEach(el => el.classList.remove('revealed'));
    
    resetIntroScene();
    mode = 'intro'; phase = 'idle'; phaseStart = lastTs = performance.now(); curSpd = C.V_SLOW;
    if (rafId) cancelAnimationFrame(rafId); rafId = requestAnimationFrame(frame);
  }

  document.addEventListener('astro:page-load', () => {
    if (!window.hj_ev) { window.addEventListener('resize', () => { if(canvas) resize(); }, { passive: true }); window.hj_ev = true; }
    start();
  });
  document.addEventListener('astro:after-swap', () => {
    if (rafId) cancelAnimationFrame(rafId);
    clearRevealTimers();
  });
  document.addEventListener('click', (e) => {
    if (e.target.id === 'hj-replay') {
      sessionStorage.removeItem('hj_intro_played');
      sessionStorage.removeItem(BG_SNAPSHOT_KEY);
      backgroundSnapshot = null;
      start();
    }
  });
</script>

