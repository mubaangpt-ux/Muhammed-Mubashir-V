---
// HyperjumpIntro.astro — Seamless Warp-to-Background Edition
// After the intro completes, the SAME canvas stays as the hero starfield.
// No canvas swap = no flash. Stars freeze at final positions with cursor ripple.
---

<canvas
  id="hj-canvas"
  aria-hidden="true"
  style="
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    will-change: opacity;
  "
></canvas>

<button
  id="hj-replay"
  aria-label="Replay intro"
  style="
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    opacity: 0.3;
    background: rgba(37,99,235,0.10);
    border: 1px solid rgba(147,197,253,0.20);
    color: #93c5fd;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: opacity 0.3s ease;
  "
  onmouseover="this.style.opacity='1'"
  onmouseout="this.style.opacity='0.3'"
>⟳ Replay</button>

<script is:inline>
(function () {
  'use strict';

  /* ═══════════════════════════════════════════════════════════════
     CONFIG — adjust anything here safely
     ═══════════════════════════════════════════════════════════════ */
  const C = {
    N:          1800,     // star count (same for intro AND hero background)

    // 3D projection
    FOCAL:       380,
    Z_FAR:      1500,
    Z_NEAR:        3,

    // Tunnel cylinder — stars sit ON this ring (forms the circular tunnel)
    R_INNER:      12,     // inner edge of ring (dark void inside this)
    R_OUTER:     150,     // outer edge

    // Phase timings (ms)
    T_IDLE:     1400,
    T_ACCEL:    1800,     // longer ramp = smoother
    T_HYPER:    1100,
    T_DECEL:    1600,     // longer ease-out = smoother
    T_FADE:     1200,     // canvas reposition fade

    // Speed (units/sec)
    V_SLOW:       22,
    V_FAST:     1500,

    // Motion blur persistence alpha
    BLUR_LO:    0.08,     // idle trail
    BLUR_HI:    0.86,     // full warp trail

    // Post-intro cursor ripple
    RIPPLE_R:    0.22,    // fraction of viewport
    RIPPLE_F:     14,     // push force in px
    SPRING:     0.05,     // return spring k

    // Star colours [R,G,B,maxAlpha]
    COLS: [
      [245, 248, 255, 0.92],
      [210, 228, 255, 0.78],
      [178, 210, 255, 0.70],
      [240, 244, 255, 0.85],
      [152, 192, 255, 0.60],
    ],

    BG: [7, 9, 15],
  };
  /* ═══════════════════════════════════════════════════════════════ */

  const canvas = document.getElementById('hj-canvas');
  const replay = document.getElementById('hj-replay');
  if (!canvas) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    canvas.style.display = 'none';
    document.body.classList.remove('hyperjump-active');
    revealHero(true);
    return;
  }

  const ctx = canvas.getContext('2d', { alpha: false });
  let W, H, cx, cy;

  /* ── Pre-allocated typed arrays (zero GC) ─── */
  const x3  = new Float32Array(C.N);
  const y3  = new Float32Array(C.N);
  const z   = new Float32Array(C.N);
  const ci  = new Uint8Array(C.N);      // colour index
  const bsz = new Float32Array(C.N);    // base size
  const stp = new Uint8Array(C.N);      // star type: 0=tunnel, 1=environment

  // Screen-space positions (for trails + cursor interaction)
  const sx  = new Float32Array(C.N);
  const sy  = new Float32Array(C.N);
  const psx = new Float32Array(C.N);    // prev screen x
  const psy = new Float32Array(C.N);    // prev screen y

  // Post-intro: home positions + velocity for cursor ripple
  const hx  = new Float32Array(C.N);    // home x
  const hy  = new Float32Array(C.N);    // home y
  const vx  = new Float32Array(C.N);    // velocity x
  const vy  = new Float32Array(C.N);    // velocity y

  function initStar(i, randZ) {
    const isTunnel = Math.random() < 0.75; // 75% stars form the tunnel
    stp[i] = isTunnel ? 0 : 1;

    const ang = Math.random() * 6.2832;
    let rr;

    if (isTunnel) {
      // Tunnel stars: concentrated ring to form a sharper circular void
      // Bias them towards R_INNER to make the "mouth" distinct
      const bias = Math.pow(Math.random(), 1.5);
      rr = C.R_INNER + bias * (C.R_OUTER * 0.8 - C.R_INNER);
    } else {
      // Environment stars: fill the sides of the screen (wide distribution)
      rr = C.R_INNER + Math.random() * (C.R_OUTER * 4);
    }

    x3[i]  = Math.cos(ang) * rr;
    y3[i]  = Math.sin(ang) * rr;
    z[i]   = randZ ? Math.random() * C.Z_FAR + C.Z_NEAR : C.Z_FAR * (0.8 + Math.random() * 0.2);
    ci[i]  = Math.random() * C.COLS.length | 0;

    // Environment stars are slightly smaller/dimmer to stay in the background
    const scale = isTunnel ? 1 : 0.7;
    bsz[i] = (Math.random() < 0.88 ? 0.35 + Math.random() * 0.65 : 0.9 + Math.random() * 1.4) * scale;
    
    const sc = C.FOCAL / z[i];
    psx[i] = sx[i] = cx + x3[i] * sc;
    psy[i] = sy[i] = cy + y3[i] * sc;
    vx[i] = vy[i] = 0;
  }

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W * 0.5;
    cy = H * 0.5;
    for (let i = 0; i < C.N; i++) initStar(i, true);
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`;
    ctx.fillRect(0, 0, W, H);
  }

  /* ── Easing ─── */
  const eIn  = t => t * t * t * t;
  const eOut = t => 1 - (1-t)*(1-t)*(1-t)*(1-t);
  const lerp = (a, b, t) => a + (b - a) * t;
  const clamp= (v,lo,hi) => v < lo ? lo : v > hi ? hi : v;

  /* ── State ─── */
  let mode       = 'intro';
  let phase      = 'idle';
  let phaseStart = 0;
  let lastTs     = 0;
  let rafId      = null;
  let mouseX     = -9999, mouseY = -9999;

  function getSpeed(ts) {
    const e = ts - phaseStart;
    if (phase === 'idle')  return C.V_SLOW;
    if (phase === 'accel') return lerp(C.V_SLOW, C.V_FAST, eIn(clamp(e / C.T_ACCEL, 0, 1)));
    if (phase === 'hyper') return C.V_FAST;
    if (phase === 'decel') return lerp(C.V_FAST, C.V_SLOW, eOut(clamp(e / C.T_DECEL, 0, 1)));
    return 0;
  }

  /* ════════════════════════════════════════════════════════════════
     INTRO RENDER LOOP
     ════════════════════════════════════════════════════════════════ */
  function introFrame(ts) {
    if (!lastTs) lastTs = ts;
    const dt = Math.min((ts - lastTs) / 1000, 0.05);
    lastTs   = ts;
    const elapsed = ts - phaseStart;

    // Phase transitions
    if      (phase === 'idle'  && elapsed > C.T_IDLE)  { phase = 'accel'; phaseStart = ts; }
    else if (phase === 'accel' && elapsed > C.T_ACCEL) { phase = 'hyper'; phaseStart = ts; }
    else if (phase === 'hyper' && elapsed > C.T_HYPER) { phase = 'decel'; phaseStart = ts; }
    else if (phase === 'decel' && elapsed > C.T_DECEL) { phase = 'done';  phaseStart = ts; }

    const spd = getSpeed(ts);
    const t01 = clamp((spd - C.V_SLOW) / (C.V_FAST - C.V_SLOW), 0, 1);

    // Motion blur overlay
    const trailA = lerp(C.BLUR_LO, C.BLUR_HI, t01 * t01);
    ctx.fillStyle = `rgba(${C.BG[0]},${C.BG[1]},${C.BG[2]},${1 - trailA})`;
    ctx.fillRect(0, 0, W, H);

    // Blue glow during warp
    if (t01 > 0.08) {
      const gA  = t01 * 0.18;
      const gR  = Math.min(W, H) * 0.6 * t01;
      const g   = ctx.createRadialGradient(cx, cy, 0, cx, cy, gR);
      g.addColorStop(0,    `rgba(37,99,235,${gA})`);
      g.addColorStop(0.5,  `rgba(20,55,180,${gA * 0.3})`);
      g.addColorStop(1,    'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, W, H);
    }

    // Move & draw stars
    const dz = spd * dt;
    for (let i = 0; i < C.N; i++) {
      z[i] -= dz;
      if (z[i] < C.Z_NEAR) { initStar(i, false); continue; }

      const sc  = C.FOCAL / z[i];
      const x2  = cx + x3[i] * sc;
      const y2  = cy + y3[i] * sc;
      const prox = 1 - z[i] / C.Z_FAR;
      const [r, g, b, ma] = C.COLS[ci[i]];
      const a   = clamp(ma * (0.12 + prox * 0.92), 0, 1);
      const ps  = bsz[i] * (0.45 + prox * 2.2);

      // Warp mode: draw line
      if (t01 > 0.04) {
        ctx.beginPath();
        ctx.strokeStyle = `rgba(${r},${g},${b},${a})`;
        ctx.lineWidth   = Math.max(0.4, ps * 0.5);
        ctx.moveTo(psx[i], psy[i]);
        ctx.lineTo(x2, y2);
        ctx.stroke();
      } else {
        ctx.beginPath();
        ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
        ctx.arc(x2, y2, Math.max(0.25, ps * 0.4), 0, 6.2832);
        ctx.fill();
      }

      psx[i] = sx[i] = x2;
      psy[i] = sy[i] = y2;
    }

    // ── DONE: transition to background mode (no flash!) ───
    if (phase === 'done') {
      const fadeT = clamp(elapsed / C.T_FADE, 0, 1);

      if (fadeT < 1) {
        rafId = requestAnimationFrame(introFrame);
        return;
      }

      // Handover: lock canvas to hero section
      mode = 'background';
      canvas.style.position  = 'absolute';
      canvas.style.zIndex    = '0';
      canvas.style.pointerEvents = 'none';

      const heroSection = document.querySelector('.hero-section');
      if (heroSection) {
        heroSection.style.position = 'relative';
        heroSection.insertBefore(canvas, heroSection.firstChild);
      }

      for (let i = 0; i < C.N; i++) {
        hx[i] = sx[i]; hy[i] = sy[i];
        vx[i] = 0;     vy[i] = 0;
      }

      document.body.classList.remove('hyperjump-active');
      replay.style.display = 'block';
      revealHero(false);

      window.addEventListener('mousemove', onMouse, { passive: true });
      window.addEventListener('mouseleave', () => { mouseX = -9999; mouseY = -9999; }, { passive: true });

      rafId = requestAnimationFrame(bgFrame);
      return;
    }

    rafId = requestAnimationFrame(introFrame);
  }

  /* ════════════════════════════════════════════════════════════════
     BACKGROUND RENDER LOOP
     ════════════════════════════════════════════════════════════════ */
  function bgFrame(ts) {
    if (!lastTs) lastTs = ts;
    lastTs = ts;

    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`;
    ctx.fillRect(0, 0, W, H);

    const rect = canvas.getBoundingClientRect();
    const mxLocal = mouseX - rect.left;
    const myLocal = mouseY - rect.top;
    const rippleR = C.RIPPLE_R * Math.min(W, H);
    const r2 = rippleR * rippleR;

    for (let i = 0; i < C.N; i++) {
      const dx = sx[i] - mxLocal;
      const dy = sy[i] - myLocal;
      const d2 = dx * dx + dy * dy;

      if (d2 < r2 && d2 > 1) {
        const t  = 1 - d2 / r2;
        const inv = 1 / Math.sqrt(d2);
        const f  = t * t * C.RIPPLE_F;
        vx[i] += dx * inv * f * 0.04;
        vy[i] += dy * inv * f * 0.04;
      }

      vx[i] += (hx[i] - sx[i]) * C.SPRING;
      vy[i] += (hy[i] - sy[i]) * C.SPRING;
      vx[i] *= 0.80;
      vy[i] *= 0.80;
      sx[i] += vx[i];
      sy[i] += vy[i];

      const [r, g, b, ma] = C.COLS[ci[i]];
      const s = bsz[i] * 0.6;
      ctx.beginPath();
      // Environment stars are slightly dimmer in background mode
      const opacity = stp[i] === 1 ? ma * 0.55 : ma * 0.85;
      ctx.fillStyle = `rgba(${r},${g},${b},${opacity})`;
      ctx.arc(sx[i], sy[i], Math.max(0.25, s), 0, 6.2832);
      ctx.fill();
    }

    rafId = requestAnimationFrame(bgFrame);
  }

  function onMouse(e) {
    mouseX = e.clientX;
    mouseY = e.clientY;
  }

  /* ════════════════════════════════════════════════════════════════
     CINEMATIC STAGGERED REVEAL
     ════════════════════════════════════════════════════════════════ */
  function revealHero(instant) {
    const header = document.querySelector('header');
    if (header) {
      if (instant) { header.classList.add('revealed'); }
      else { setTimeout(() => header.classList.add('revealed'), 150); }
    }

    const items = Array.from(document.querySelectorAll('.reveal'));
    items.forEach((el, i) => {
      if (instant) {
        el.classList.add('revealed');
        return;
      }
      const delayMs = el.dataset.delay
        ? parseFloat(el.dataset.delay) * 1000
        : i * 130;
      setTimeout(() => el.classList.add('revealed'), 450 + delayMs);
    });
  }

  /* ════════════════════════════════════════════════════════════════
     BOOT / REPLAY
     ════════════════════════════════════════════════════════════════ */
  function start() {
    canvas.style.position  = 'fixed';
    canvas.style.inset     = '0';
    canvas.style.zIndex    = '9999';
    canvas.style.display   = 'block';
    canvas.style.opacity   = '1';
    replay.style.display   = 'none';

    if (canvas.parentElement !== document.body) {
      document.body.insertBefore(canvas, document.body.firstChild);
    }

    document.body.classList.add('hyperjump-active');

    document.querySelectorAll('.reveal').forEach(el => el.classList.remove('revealed'));
    const header = document.querySelector('header');
    if (header) header.classList.remove('revealed');

    resize();
    mode       = 'intro';
    phase      = 'idle';
    phaseStart = lastTs = performance.now();

    window.removeEventListener('mousemove', onMouse);
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(introFrame);
  }

  window.addEventListener('resize', () => {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W * 0.5;
    cy = H * 0.5;
  }, { passive: true });

  replay.addEventListener('click', start);
  start();
})();
</script>

<style is:global>
  body.hyperjump-active {
    overflow: hidden;
  }

  /* Header reveal — slides down */
  header {
    opacity: 0;
    transform: translateY(-16px);
    transition:
      opacity   0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }
  header.revealed {
    opacity: 1;
    transform: none;
  }

  /* Hero element reveal — slides up + fades in */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   0.80s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.80s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }
  .reveal.revealed {
    opacity: 1;
    transform: none;
  }

  /* Glass / metric cards — scale-in effect */
  .glass-panel.reveal,
  .glass-card.reveal,
  [class*="cap-card"].reveal,
  .metric-card.reveal {
    transform: translateY(36px) scale(0.96);
    transition:
      opacity   0.90s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.90s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .glass-panel.reveal.revealed,
  .glass-card.reveal.revealed,
  [class*="cap-card"].reveal.revealed,
  .metric-card.reveal.revealed {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    header,
    .reveal,
    .reveal.revealed {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
