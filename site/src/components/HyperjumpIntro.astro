---
// HyperjumpIntro.astro — Ultra-Realistic 3D Warp Tunnel
// Stars spawn in a 3D cylindrical ring to ensure the "loop" void in the center.
// Unified engine: no canvas swap or frame resets between intro and background.
---

<canvas
  id="hj-canvas"
  aria-hidden="true"
  style="
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    will-change: opacity;
  "
></canvas>

<button
  id="hj-replay"
  aria-label="Replay intro"
  style="
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    opacity: 0.3;
    background: rgba(37,99,235,0.10);
    border: 1px solid rgba(147,197,253,0.20);
    color: #93c5fd;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: opacity 0.3s ease;
  "
  onmouseover="this.style.opacity='1'"
  onmouseout="this.style.opacity='0.3'"
>⟳ Replay</button>

<script>
  /* ═══════════════════════════════════════════════════════════════
     CONFIG & PERSISTENT STATE
     ═══════════════════════════════════════════════════════════════ */
  const C = {
    N:          3500,
    FOCAL:       380,
    Z_FAR:      1600,
    Z_NEAR:        3,
    R_INNER:      22,     // sharper hole
    R_OUTER:     180,     
    T_IDLE:     1000,
    T_ACCEL:    2000,
    T_HYPER:    1000,
    T_DECEL:    2200,
    T_FADE:     1200,
    V_SLOW:       15,
    V_FAST:     1650,
    BLUR_LO:    0.06,
    BLUR_HI:    0.90,
    RIPPLE_R:    0.28,
    RIPPLE_F:     18,
    SPRING:     0.05,
    BG_EXPAND:   6.85,
    BG_SEED:  0x4d554241,
    COLS: [
      [255, 255, 255, 1.0], [147, 197, 253, 0.9],
      [59, 130, 246, 0.8], [219, 234, 254, 0.95]
    ],
    BG: [7, 9, 15]
  };

  // Persistent engine state (survives client-side navigation)
  let canvas, ctx, replay, W, H, cx, cy;
  let rafId = null, lastTs = 0, phaseStart = 0;
  let phase = 'idle', mode = 'intro', curSpd = C.V_SLOW, expFactor = 1.0;
  let mouseX = -9999, mouseY = -9999;
  let initialized = false;
  let backgroundPrepared = false;
  let bgEventsBound = false;

  const x3 = new Float32Array(C.N), y3 = new Float32Array(C.N), z3 = new Float32Array(C.N);
  const ci = new Uint8Array(C.N), bsz = new Float32Array(C.N);
  const sx = new Float32Array(C.N), sy = new Float32Array(C.N), psx = new Float32Array(C.N), psy = new Float32Array(C.N);
  const hx = new Float32Array(C.N), hy = new Float32Array(C.N), vx = new Float32Array(C.N), vy = new Float32Array(C.N);

  function createSeededRandom(seed) {
    let state = seed >>> 0;
    return () => {
      state = (state * 1664525 + 1013904223) >>> 0;
      return state / 4294967296;
    };
  }

  function initStar(i, randZ, random = Math.random) {
    const tunnel = random() < 0.75;
    const a = random() * 6.2831;
    const r = tunnel ? C.R_INNER + random() * (C.R_OUTER - C.R_INNER) : random() * (C.R_OUTER * 15);
    x3[i] = Math.cos(a) * r; y3[i] = Math.sin(a) * r;
    z3[i] = randZ ? random() * C.Z_FAR + C.Z_NEAR : C.Z_FAR * (0.8 + random() * 0.2);
    ci[i] = random() * C.COLS.length | 0;
    bsz[i] = (random() < 0.9 ? 0.4 + random() * 0.6 : 1.0 + random() * 1.5) * (tunnel ? 1 : 0.65);
    vx[i] = vy[i] = 0;
    const psc = C.FOCAL / z3[i]; 
    const px = x3[i] * psc + (W / 2);
    const py = y3[i] * psc + (H / 2);
    psx[i] = sx[i] = hx[i] = px; 
    psy[i] = sy[i] = hy[i] = py;
  }

  function resetIntroScene() {
    for (let i = 0; i < C.N; i++) initStar(i, true);
    backgroundPrepared = false;
  }

  function prepareBackgroundScene() {
    const random = createSeededRandom(C.BG_SEED);
    for (let i = 0; i < C.N; i++) {
      initStar(i, false, random);
      const sc = C.FOCAL / z3[i];
      const px = cx + x3[i] * sc * C.BG_EXPAND;
      const py = cy + y3[i] * sc * C.BG_EXPAND;
      psx[i] = sx[i] = hx[i] = px;
      psy[i] = sy[i] = hy[i] = py;
      vx[i] = vy[i] = 0;
    }
    backgroundPrepared = true;
  }

  function mountBackgroundCanvas() {
    canvas.style.position = 'fixed';
    canvas.style.inset = '0';
    canvas.style.width = '100vw';
    canvas.style.height = '100vh';
    canvas.style.zIndex = '0';
    if (canvas.parentElement !== document.body) {
      document.body.insertBefore(canvas, document.body.firstChild);
    }
  }

  function onMouseLeave() {
    mouseX = -9999;
    mouseY = -9999;
  }

  function bindBackgroundEvents() {
    if (bgEventsBound) return;
    window.addEventListener('mousemove', onMouse, { passive: true });
    window.addEventListener('mouseleave', onMouseLeave, { passive: true });
    bgEventsBound = true;
  }

  function resize() {
    W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight;
    cx = W * 0.5; cy = H * 0.5;
    if (!initialized) {
      resetIntroScene();
      initialized = true;
    } else if (mode === 'background' && backgroundPrepared) {
      prepareBackgroundScene();
    }
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`; ctx.fillRect(0, 0, W, H);
  }

  const eIn = t => t * t * t * t * t, eOut = t => 1 - Math.pow(1 - t, 5);
  const lerp = (a, b, t) => a + (b - a) * t, clamp = (v, lo, hi) => v < lo ? lo : v > hi ? hi : v;

  function frame(ts) {
    if (!lastTs) lastTs = ts;
    const dt = Math.min((ts - lastTs) / 1000, 0.05); lastTs = ts;
    const el = ts - phaseStart;

    if (phase === 'idle' && el > C.T_IDLE) { phase = 'accel'; phaseStart = ts; }
    else if (phase === 'accel' && el > C.T_ACCEL) { phase = 'hyper'; phaseStart = ts; }
    else if (phase === 'hyper' && el > C.T_HYPER) { phase = 'decel'; phaseStart = ts; }
    else if (phase === 'decel' && el > C.T_DECEL) { phase = 'done'; phaseStart = ts; }

    const target = (phase === 'idle') ? C.V_SLOW : (phase === 'accel') ? lerp(C.V_SLOW, C.V_FAST, eIn(clamp(el/C.T_ACCEL,0,1))) : (phase === 'hyper') ? C.V_FAST : (phase === 'decel') ? lerp(C.V_FAST, C.V_SLOW, eOut(clamp(el/C.T_DECEL,0,1))) : 0;
    curSpd = lerp(curSpd, target, 0.15);
    const t01 = clamp((curSpd - C.V_SLOW) / (C.V_FAST - C.V_SLOW), 0, 1);

    ctx.fillStyle = `rgba(${C.BG[0]},${C.BG[1]},${C.BG[2]},${1 - lerp(C.BLUR_LO, C.BLUR_HI, t01)})`; ctx.fillRect(0, 0, W, H);

    if (phase === 'decel' || phase === 'done') {
      const alpha = clamp(el / (phase === 'decel' ? C.T_DECEL : C.T_FADE), 0, 1) * 0.45;
      const g = ctx.createRadialGradient(cx, -cy * 0.1, 0, cx, -cy * 0.1, W * 0.7);
      g.addColorStop(0, `rgba(37,99,235,${alpha * 0.8})`); g.addColorStop(0.4, `rgba(37,99,235,${alpha * 0.3})`); g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.globalCompositeOperation = 'screen'; ctx.fillStyle = g; ctx.fillRect(0, 0, W, H); ctx.globalCompositeOperation = 'source-over';
    }

    expFactor = (phase === 'decel' || phase === 'done') ? 1.0 + eOut(el / C.T_DECEL) * 6.0 : 1.0;
    const dz = curSpd * dt;

    for (let i = 0; i < C.N; i++) {
      if (phase !== 'done') {
        z3[i] -= dz; if (z3[i] < C.Z_NEAR) { 
          initStar(i, false); const sc2 = C.FOCAL / z3[i]; psx[i] = cx + x3[i]*sc2*expFactor; psy[i] = cy + y3[i]*sc2*expFactor; 
        }
      }
      const sc = C.FOCAL / z3[i], x = cx + x3[i]*sc*expFactor, y = cy + y3[i]*sc*expFactor;
      const p = 1 - z3[i] / C.Z_FAR, [r, g, b, ma] = C.COLS[ci[i]], a = clamp(ma*(0.15+p*0.85),0,1), s = bsz[i]*(0.6+p*1.8);
      if (t01 > 0.05 && phase !== 'done') {
        ctx.beginPath(); ctx.strokeStyle = `rgba(${r},${g},${b},${a})`; ctx.lineWidth = Math.max(0.6, s*0.5);
        ctx.moveTo(psx[i], psy[i]); ctx.lineTo(x, y); ctx.stroke();
      } else {
        ctx.beginPath(); ctx.fillStyle = `rgba(${r},${g},${b},${a * (mode==='background'?0.7:1)})`;
        ctx.arc(x, y, Math.max(0.35, s*0.45), 0, 6.2831); ctx.fill();
      }
      psx[i] = x; psy[i] = y; sx[i] = x; sy[i] = y;
    }

    if (phase === 'done' && clamp(el / C.T_FADE, 0, 1) >= 1 && mode === 'intro') {
      sessionStorage.setItem('hj_intro_played', 'true'); finishIntro(); return;
    }
    rafId = requestAnimationFrame(frame);
  }

  function finishIntro(wasSkipped) {
    if (!canvas) return;
    mode = 'background';
    mountBackgroundCanvas();
    prepareBackgroundScene();
    canvas.style.display = 'block'; 
    canvas.style.opacity = '1';
    canvas.style.pointerEvents = 'none';
    document.body.classList.remove('hyperjump-active');
    if (replay) replay.style.display = 'block';
    
    revealHero(wasSkipped);
    bindBackgroundEvents();
    document.dispatchEvent(new CustomEvent('hyperjump-complete'));
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(bgLoop);
  }

  function bgLoop(ts) {
    ctx.fillStyle = `rgb(${C.BG[0]},${C.BG[1]},${C.BG[2]})`; ctx.fillRect(0, 0, W, H);
    const g = ctx.createRadialGradient(cx, -cy * 0.1, 0, cx, -cy * 0.1, W * 0.7);
    g.addColorStop(0, `rgba(37,99,235,0.35)`); g.addColorStop(0.4, `rgba(37,99,235,0.12)`); g.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.globalCompositeOperation = 'screen'; ctx.fillStyle = g; ctx.fillRect(0, 0, W, H); ctx.globalCompositeOperation = 'source-over';

    const r = canvas.getBoundingClientRect();
    const mxL = mouseX - r.left, myL = mouseY - r.top, r2 = (C.RIPPLE_R * Math.min(W, H)) ** 2;
    for (let i = 0; i < C.N; i++) {
        const dx = sx[i] - mxL, dy = sy[i] - myL, d2 = dx*dx + dy*dy;
        if (d2 < r2 && d2 > 0.1) {
            const t = 1 - d2/r2, f = t*t*C.RIPPLE_F, inv = 1/Math.sqrt(d2);
            vx[i] += dx*inv*f*0.05; vy[i] += dy*inv*f*0.05;
        }
        vx[i] += (hx[i] - sx[i]) * C.SPRING; vy[i] += (hy[i] - sy[i]) * C.SPRING;
        vx[i] *= 0.8; vy[i] *= 0.8; sx[i] += vx[i]; sy[i] += vy[i];
        const [rc, gc, bc, ma] = C.COLS[ci[i]];
        ctx.beginPath(); ctx.fillStyle = `rgba(${rc},${gc},${bc},${ma*0.7})`;
        ctx.arc(sx[i], sy[i], Math.max(0.35, bsz[i]*0.6), 0, 6.2831); ctx.fill();
    }
    rafId = requestAnimationFrame(bgLoop);
  }

  function onMouse(e) { mouseX = e.clientX; mouseY = e.clientY; }

  function revealHero(instant) {
    const header = document.querySelector('header');
    if (header) { 
      header.classList.add('revealed'); 
      if (instant) header.style.transition = 'none'; 
    }
    const reveals = document.querySelectorAll('.reveal');
    reveals.forEach((el, i) => {
      if (instant) { 
        el.classList.add('revealed'); 
        el.style.transition = 'none'; 
        return; 
      }
      // Group-based delays for cinematic effect
      const d = el.dataset.delay ? parseFloat(el.dataset.delay) * 1000 : i * 150;
      setTimeout(() => el.classList.add('revealed'), 400 + d);
    });
  }

  function start() {
    canvas = document.getElementById('hj-canvas'); replay = document.getElementById('hj-replay');
    if (!canvas) return; ctx = canvas.getContext('2d', { alpha: false }); resize();
    
    const played = sessionStorage.getItem('hj_intro_played'), isHome = window.location.pathname === '/' || window.location.pathname.endsWith('/index.html');
    if (played || !isHome) { finishIntro(true); return; }

    canvas.style.position = 'fixed'; canvas.style.zIndex = '9999'; canvas.style.display = 'block'; canvas.style.opacity = '1';
    if (canvas.parentElement !== document.body) document.body.insertBefore(canvas, document.body.firstChild);
    document.body.classList.add('hyperjump-active');
    document.querySelectorAll('.reveal').forEach(el => el.classList.remove('revealed'));
    
    resetIntroScene();
    mode = 'intro'; phase = 'idle'; phaseStart = lastTs = performance.now(); curSpd = C.V_SLOW;
    if (rafId) cancelAnimationFrame(rafId); rafId = requestAnimationFrame(frame);
  }

  document.addEventListener('astro:page-load', () => {
    if (!window.hj_ev) { window.addEventListener('resize', () => { if(canvas) resize(); }, { passive: true }); window.hj_ev = true; }
    start();
  });
  document.addEventListener('astro:after-swap', () => { if (rafId) cancelAnimationFrame(rafId); });
  document.addEventListener('click', (e) => { if (e.target.id === 'hj-replay') { sessionStorage.removeItem('hj_intro_played'); start(); } });
</script>

<style is:global>
  body.hyperjump-active { overflow: hidden; height: 100vh; }
  header { opacity: 0; transform: translateY(-12px); transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1); }
  header.revealed { opacity: 1; transform: none; }
  .reveal { opacity: 0; transform: translateY(24px); transition: all 1s cubic-bezier(0.22, 1, 0.36, 1); will-change: transform, opacity; }
  .reveal.revealed { opacity: 1; transform: none; }
  .glass-panel.reveal, .glass-card.reveal, [class*="cap-card"].reveal, .metric-card.reveal {
     transform: translateY(24px) scale(0.985); transition: all 1.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .glass-panel.reveal.revealed, .glass-card.reveal.revealed, [class*="cap-card"].reveal.revealed, .metric-card.reveal.revealed {
     transform: none;
  }
</style>
