<IfModule mod_rewrite.c>
RewriteEngine On

# Force the single canonical domain for crawlers and share preview bots.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.mubaan\.online$ [NC]
RewriteRule ^ https://mubaan.online%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_headers.c>
# Hostinger is currently returning Retry-After on normal 200 responses.
# Some preview bots treat that as a temporary back-off signal and skip card generation.
Header always unset Retry-After
</IfModule>
